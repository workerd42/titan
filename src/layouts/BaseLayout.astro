---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  theme?: 'light' | 'dark';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalPath,
  theme = 'light',
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${base}${canonicalPath}`;
const pageTitle = title === 'Titan' ? title : `${title} — Titan`;

// Basis-Strukturdaten für jede Seite — Einzelseiten können über die
// jsonLd-Prop spezifischere Schemas (z. B. LearningResource) mitgeben.
const finalJsonLd = jsonLd ?? {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Titan',
  description: 'Digitales Kompetenzsystem für die IHK-Fortbildungsprüfung Geprüfte/r Fachwirt/in für Marketing.',
  url: `${siteUrl}${base}/`,
};
---

<!doctype html>
<html lang="de" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {/* Prototyp-/Staging-Zustand — bewusst noch nicht indexierbar, siehe auch robots.txt. */}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    {/* Kein og:image — es gibt noch keine echte Grafik unter public/og-image.png;
        eine gebrochene Bild-URL ist schlechter als gar keine (leere Vorschau
        statt kaputtem Bild bei Social-Shares). Sobald ein Bild existiert,
        hier wieder ergänzen. */}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- CSP — nur im Production-Build aktiv, nicht im Dev-Server -->
    <!-- Im Dev-Modus würde connect-src 'none' den HMR-WebSocket blockieren -->
    {!import.meta.env.DEV && (
      <meta
        http-equiv="Content-Security-Policy"
        content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'"
      />
    )}

    <meta name="theme-color" content={theme === 'dark' ? '#141210' : '#EDE8DF'} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Lesemodus-Theme: wendet die gespeicherte Nutzerwahl VOR dem Paint an
         (kein Flash) und erneut nach jeder View-Transition-Navigation. Nur eine
         explizite Wahl überschreibt den Seiten-Default (helle Lernwelt / dunkler
         Kosmos). `is:inline`, damit es sofort läuft. -->
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem('titan-theme');
            if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />

    <!-- View Transitions — Astro 7 ClientRouter -->
    <ClientRouter />
  </head>
  <body>
    <a href="#hauptinhalt" class="skip-link">Zum Hauptinhalt springen</a>
    <slot />
  </body>
</html>
