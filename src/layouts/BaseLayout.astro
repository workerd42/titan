---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  theme?: 'light' | 'dark';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalPath,
  theme = 'light',
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${base}${canonicalPath}`;
const pageTitle = title === 'Titan' ? title : `${title} — Titan`;
---

<!doctype html>
<html lang="de" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={`${siteUrl}${base}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- CSP — nur im Production-Build aktiv, nicht im Dev-Server -->
    <!-- Im Dev-Modus würde connect-src 'none' den HMR-WebSocket blockieren -->
    {!import.meta.env.DEV && (
      <meta
        http-equiv="Content-Security-Policy"
        content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'none'; base-uri 'self'; form-action 'none'"
      />
    )}

    <meta name="theme-color" content={theme === 'dark' ? '#141210' : '#EDE8DF'} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- View Transitions — Astro 7 ClientRouter -->
    <ClientRouter />
  </head>
  <body>
    <a href="#hauptinhalt" class="skip-link">Zum Hauptinhalt springen</a>
    <slot />
  </body>
</html>
