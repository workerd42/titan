---
import BaseLayout from './BaseLayout.astro';
import KompassOnboarding from '../components/ui/KompassOnboarding.astro';
import PersoenlichPanel from '../components/ui/PersoenlichPanel.astro';
import KonzeptPanel from '../components/ui/KonzeptPanel.astro';
import SpeedDial from '../components/ui/SpeedDial.astro';
import SearchOverlay from '../components/ui/SearchOverlay.astro';
import { getThemenSlugsByHb } from '../lib/content';
import '../styles/space.css';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  showPersonal?: boolean;
  /**
   * Suche einblenden. Bewusst nur ab der Kapitel-/Planeten-Ebene (Seite 3)
   * sinnvoll — auf Universum-/Galaxie-Auswahl (Seite 1+2) gibt es kaum etwas
   * zu durchsuchen, dort lenkt die Lupe nur ab. Default: aus.
   */
  showSearch?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonicalPath, showPersonal = true, showSearch = false, jsonLd } = Astro.props;
const base = import.meta.env.BASE_URL;

// Slugs pro HB für Fortschrittsanzeige im persönlichen Panel
const themenSlugs = await getThemenSlugsByHb();
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  theme="dark"
  jsonLd={jsonLd}
>
  <div class="space-shell" data-theme="dark">
    <canvas id="starfield-canvas" aria-hidden="true" role="presentation"></canvas>

    <!-- Navigation -->
    <nav class="space-nav space-content" aria-label="Titan Hauptnavigation">
      <a href={base} class="norive-wordmark" aria-label="Titan — Startseite">
        Titan
      </a>
    </nav>

    <!-- Hauptinhalt -->
    <main id="hauptinhalt" tabindex="-1" class="space-content">
      <slot />
    </main>

    <!-- Kompass-Onboarding -->
    <KompassOnboarding />

    <!-- Suche — nur ab Kapitel-/Planeten-Ebene (Seite 3), siehe showSearch -->
    {showSearch && <SearchOverlay />}

    <!-- Persönlicher Bereich (optional deaktivierbar) — Trigger im Speed-Dial -->
    {showPersonal && (
      <>
        <KonzeptPanel />
        <PersoenlichPanel alleThemenSlugs={themenSlugs} />
        <SpeedDial showKonzept={true} showPersonal={true} />
      </>
    )}
  </div>
</BaseLayout>

<!-- GSAP Universe Animations -->
<script>
  import { initUniverseAnimations } from '../scripts/gsap-universe';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initUniverseAnimations);
  } else {
    initUniverseAnimations();
  }
</script>

<!-- Progress Tracking -->
<script src="../scripts/norive-progress.ts"></script>

<!-- Local-First-Sync: no-op ohne Login, gleicht mit Account ab wenn angemeldet -->
<script src="../scripts/norive-sync.ts"></script>
