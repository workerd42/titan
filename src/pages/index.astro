---
/**
 * Universum-Auswahl — WAHRE Startseite (Ebene 1 der Hierarchie).
 *
 * Strukturell identisch zur Galaxie-Auswahl (gleiches Karussell- und
 * Caption-Verhalten), datengetrieben aus data/universen.ts. Aktuell
 * existiert ein Universum (Fachwirt Marketing); das System skaliert
 * ohne Codeänderung, sobald weitere Universen ergänzt werden.
 */
export const prerender = false;

import SpaceLayout from '../layouts/SpaceLayout.astro';
import CarouselStage from '../components/space/CarouselStage.astro';
import CarouselCaption from '../components/ui/CarouselCaption.astro';
import UniversumGlobe from '../components/space/UniversumGlobe.astro';
import InfoButton from '../components/ui/InfoButton.astro';
import { BEREICHE } from '../data/bereiche';
import { UNIVERSEN } from '../data/universen';

const base = import.meta.env.BASE_URL;

function galaxienVon(universumId: string) {
  return BEREICHE.filter((b) => b.universumId === universumId);
}
---

<SpaceLayout
  title="Titan"
  description="Digitales Kompetenzsystem für die berufliche Weiterbildung — wähle dein Universum."
  canonicalPath="/"
  showPersonal={true}
>
  <CarouselStage stageId="kosmos-stage" universumId="titan-kosmos" itemCount={UNIVERSEN.length}>
    {UNIVERSEN.map((u, i) => (
      <UniversumGlobe
        universumId={u.id}
        nummer={u.nummer}
        titel={u.titel}
        eyebrow={u.eyebrow}
        beschreibung={u.beschreibung}
        href={`${base}${u.id}/`}
        galaxienCount={galaxienVon(u.id).length}
        index={i}
        color={u.color}
        comingSoon={u.comingSoon}
      />
    ))}

    <CarouselCaption slot="caption" />
  </CarouselStage>

  <InfoButton />
</SpaceLayout>

<script>
  import { initCarousel, responsivePlanetSize, wireDots, updateDots, type CarouselController } from '../scripts/gsap-carousel';
  import { createCaptionSync, type CaptionSync } from '../scripts/carousel-caption';
  import { initFocusView, openFocus } from '../scripts/focus-view';
  import { gsap } from 'gsap';

  const BASE_SIZE = 245; // Vordere Kugel ~2,5× (Rest der Größe via Perspektive/rz)

  let controller: CarouselController | null = null;
  let caption: CaptionSync | null = null;

  function initPage(): void {
    const stage = document.getElementById('kosmos-stage');
    const track = document.getElementById('kosmos-stage-track');
    if (!stage || !track) return;

    // Light-Mode Setup
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement | null;
    if (canvas) canvas.style.display = 'none';
    const nav      = document.querySelector<HTMLElement>('.space-nav');
    const wordmark = document.querySelector<HTMLElement>('.norive-wordmark');
    if (nav)      nav.style.background = 'linear-gradient(to bottom, rgba(237,232,223,0.85) 0%, transparent 100%)';
    if (wordmark) wordmark.style.color  = '#6E5035';

    const planetEls = Array.from(document.querySelectorAll<HTMLElement>('.universum-planet'));

    // ── STATE RESET (ClientRouter Back-Navigation) ──
    controller?.destroy();
    caption?.destroy();
    controller = null;
    caption = null;
    gsap.killTweensOf(planetEls);
    planetEls.forEach(el => { el.style.cssText = ''; });

    // ── Größen ──
    planetEls.forEach((el) => {
      const size = responsivePlanetSize(BASE_SIZE);
      el.style.width  = `${size}px`;
      el.style.height = `${size}px`;
    });

    // ── Caption-Sync (Modell B+: Caption folgt Zentrierung, kein Zoom-Schritt) ──
    const captionRoot = document.getElementById('carousel-caption');
    if (captionRoot) {
      caption = createCaptionSync({
        root: captionRoot,
        eyebrow: document.getElementById('cc-eyebrow'),
        titel: document.getElementById('cc-titel'),
        beschr: document.getElementById('cc-beschr'),
        cta: document.getElementById('cc-cta') as HTMLAnchorElement | null,
        ctaText: document.getElementById('cc-cta-text'),
      }, (el) => {
        const comingSoon = el.dataset.comingSoon === 'true';
        return {
          eyebrow: el.dataset.eyebrow ?? '',
          titel:   el.dataset.titel ?? '',
          beschr:  comingSoon
            ? (el.dataset.beschreibung ?? '')
            : `${el.dataset.beschreibung ?? ''} — ${el.dataset.galaxien ?? '?'} Handlungsfelder`,
          href:    comingSoon ? '' : (el as HTMLAnchorElement).href,
          ctaText: comingSoon ? 'Bald verfügbar' : 'Universum betreten',
        };
      });
    }

    // ── Karussell (auch im Degenerierten Fall N=1 unproblematisch: goTo/next/prev clampen) ──
    controller = initCarousel({
      container: track,
      items: planetEls,
      orientation: 'horizontal',
      mode: 'ring',
      showHint: true,
      onCenterChange: (i, el) => { caption?.sync(el); updateDots('kosmos-stage', i); },
    });
    wireDots('kosmos-stage', controller);

    document.getElementById('kosmos-stage-prev')?.addEventListener('click', () => controller?.prev());
    document.getElementById('kosmos-stage-next')?.addEventListener('click', () => controller?.next());

    // ── Zoom-Zwischenschritt (#4): CTA öffnet den Fokus statt direkt zu
    // navigieren. „Weiter" im Fokus führt dann zur Universum-Seite. ──
    initFocusView();
    const cta = document.getElementById('cc-cta') as HTMLAnchorElement | null;
    cta?.addEventListener('click', (e) => {
      if (cta.classList.contains('is-disabled') || !cta.getAttribute('href')) return; // Coming-Soon
      e.preventDefault();
      const idx = controller?.getCenterIndex() ?? 0;
      const globe = planetEls[idx];
      if (!globe) { window.location.href = cta.href; return; }
      openFocus(globe, {
        eyebrow: globe.dataset.eyebrow ?? '',
        titel:   globe.dataset.titel ?? '',
        beschr:  globe.dataset.beschreibung ?? '',
        meta:    `${globe.dataset.galaxien ?? '?'} Handlungsfelder`,
        href:    (globe as HTMLAnchorElement).href,
        weiterText: 'Universum betreten',
      });
    });
  }

  // astro:page-load feuert bereits beim initialen Laden (Astro-Standard) —
  // ein zusätzlicher direkter Aufruf würde initPage() doppelt ausführen.
  document.addEventListener('astro:page-load', initPage);
</script>
