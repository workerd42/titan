---
import SpaceLayout from '../../layouts/SpaceLayout.astro';
import Universe from '../../components/space/Universe.astro';
import GalaxieGlobe from '../../components/space/GalaxieGlobe.astro';
import { BEREICHE } from '../../data/bereiche';
import { UNIVERSEN, getUniversum } from '../../data/universen';

export async function getStaticPaths() {
  return UNIVERSEN.map((u) => ({ params: { universum: u.id } }));
}
import { getCollection } from 'astro:content';

const { universum: universumId } = Astro.params;
const universum = getUniversum(universumId as string)!;
const bereicheDesUniversums = BEREICHE.filter((b) => b.universumId === universum.id);

const alleThemen = await getCollection('themen');
const base = import.meta.env.BASE_URL;
const uBase = `${base}${universum.id}/`;

function themenVon(hbId: string) {
  return alleThemen.filter(t => t.data.handlungsbereich === hbId);
}

// Farbwelten + Orbit-Zuordnung der vier Handlungsfelder
const PLANET_CONFIG = [
  { highlight: '#E8C480', base: '#3D2B1A', rim: 'rgba(232,196,128,0.45)', atmo: 'rgba(196,168,80,0.25)',  orbitIdx: 0, startAngle: -0.4 },
  { highlight: '#7AC0E8', base: '#1E2A3E', rim: 'rgba(122,192,232,0.4)',  atmo: 'rgba(80,140,220,0.2)',   orbitIdx: 1, startAngle:  2.1 },
  { highlight: '#7AC898', base: '#1A2E20', rim: 'rgba(120,200,152,0.4)',  atmo: 'rgba(60,180,100,0.18)',  orbitIdx: 2, startAngle: -1.8 },
  { highlight: '#C880D8', base: '#2E1A3E', rim: 'rgba(200,128,216,0.4)',  atmo: 'rgba(160,80,200,0.18)',  orbitIdx: 3, startAngle:  1.2 },
];

// Orbitalbahnen in % (SVG viewBox 0 0 100 100)
const ORBITS = [
  { rx: 18, ry: 7.5  },
  { rx: 28, ry: 11.5 },
  { rx: 37, ry: 15.5 },
  { rx: 45, ry: 18.5 },
];
---

<SpaceLayout
  title={universum.titel}
  description={universum.beschreibung}
  canonicalPath={`/${universum.id}/`}
  showPersonal={true}
>
  <a href={base} class="galaxie-back-link" aria-label="Zurück zur Universum-Auswahl">
    ← Alle Universen
  </a>

  <Universe
    stageId="solar-stage"
    centralId="solar-center"
    universumId={universum.id}
    orbits={ORBITS}
    central={{ h: '#F0D880', b: '#C48830' }}
    centralLabel="Titan"
    centralSize="lg"
  >
    {bereicheDesUniversums.map((b, i) => {
      const themen = themenVon(b.id);
      const cfg = PLANET_CONFIG[i];
      return (
        <GalaxieGlobe
          hfId={b.id}
          nummer={b.nummer}
          titel={b.titel}
          beschreibung={b.beschreibung}
          href={`${uBase}${b.id}/`}
          themenCount={themen.length}
          hbSlugs={themen.map(t => t.id)}
          orbitIdx={cfg.orbitIdx}
          startAngle={cfg.startAngle}
          color={cfg}
        />
      );
    })}

    <div class="solar-intro" id="solar-intro">
      <p>{universum.eyebrow}</p>
      <p>Wähle ein Handlungsfeld</p>
    </div>
  </Universe>
</SpaceLayout>

<script>
  import { initDraggableOrbits, introAnimation, responsivePlanetSize } from '../../scripts/gsap-orbits';
  import { createFocusController, type FocusController } from '../../scripts/gsap-focus';
  import { gsap } from 'gsap';

  const ORBITS = [
    { rx: 18, ry: 7.5  },
    { rx: 28, ry: 11.5 },
    { rx: 37, ry: 15.5 },
    { rx: 45, ry: 18.5 },
  ];
  const BASE_SIZES = [100, 80, 68, 90];
  const PROGRESS_KEY = 'norive-progress-v2';

  let controller: FocusController | null = null;

  /** Fortschritt eines HF in % — zählt NUR die Themen dieses HF (data-hb-slugs). */
  function hbProgress(el: HTMLElement): number {
    try {
      const slugs = (el.dataset.hbSlugs ?? '').split(',').filter(Boolean);
      if (!slugs.length) return 0;
      const st = JSON.parse(localStorage.getItem(PROGRESS_KEY) || '{}');
      const themen = (st as any).themen ?? {};
      let done = 0;
      slugs.forEach(slug => {
        const t = themen[slug];
        if (t) done += (t.verstehen?1:0)+(t.merken?1:0)+(t.anwenden?1:0)+(t.pruefen?1:0);
      });
      return Math.round((done / (slugs.length * 4)) * 100);
    } catch { return 0; }
  }

  function initPage(): void {
    const stage = document.getElementById('solar-stage');
    if (!stage) return;

    // Light-Mode Setup
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement | null;
    if (canvas) canvas.style.display = 'none';
    const nav      = document.querySelector<HTMLElement>('.space-nav');
    const wordmark = document.querySelector<HTMLElement>('.norive-wordmark');
    if (nav)      nav.style.background = 'linear-gradient(to bottom, rgba(237,232,223,0.85) 0%, transparent 100%)';
    if (wordmark) wordmark.style.color  = '#6E5035';

    const orbitSvg  = stage.querySelector<HTMLElement>('.orbit-svg');
    const central   = document.getElementById('solar-center');
    const introEl   = document.getElementById('solar-intro');
    const planetEls = Array.from(document.querySelectorAll<HTMLElement>('.hf-planet'));

    // ── STATE RESET (ClientRouter Back-Navigation) ──
    controller?.destroy();
    controller = null;
    gsap.killTweensOf(planetEls);
    if (orbitSvg) { gsap.killTweensOf(orbitSvg); gsap.set(orbitSvg, { clearProps: 'all' }); }
    if (central)  { gsap.killTweensOf(central);  gsap.set(central,  { clearProps: 'all' }); }
    if (introEl)  introEl.style.display = '';
    planetEls.forEach(el => { el.style.cssText = ''; });

    // ── Größen + Telemetrie (data-progress-hb) ──
    planetEls.forEach((el, i) => {
      const size = responsivePlanetSize(BASE_SIZES[i] ?? 80);
      el.style.width  = `${size}px`;
      el.style.height = `${size}px`;
      el.dataset.progressHb = String(hbProgress(el));
    });

    // ── 3-STATE FOCUS CONTROLLER ──
    controller = createFocusController({
      stage,
      planets: planetEls,
      systemParts: [orbitSvg, central, introEl],
      heroSize: () => Math.min(560, window.innerWidth * 0.42, window.innerHeight * 0.68),
      getData: (el) => ({
        eyebrow: `Handlungsfeld ${el.dataset.nummer ?? ''}`,
        titel:   el.dataset.titel ?? '',
        beschr:  `${el.dataset.beschreibung ?? ''} — ${el.dataset.themen ?? '?'} Kapitel · ${el.dataset.progressHb ?? 0} % abgeschlossen`,
        href:    (el as HTMLAnchorElement).href,
        ctaText: 'Handlungsfeld betreten',
      }),
    });

    // ── Drag-System: Klick (ohne Drag) → STATE 2 ──
    const bodies = planetEls.map(el => ({
      el,
      orbitIndex: parseInt(el.dataset.orbit ?? '0'),
      startAngle: parseFloat(el.dataset.start ?? '0'),
    }));

    initDraggableOrbits(stage, ORBITS, bodies, (body, wasDragged) => {
      if (wasDragged || !controller) return;
      if (controller.isActive()) return; // Fokussiert → nur CTA/Ghost-Button bedienbar
      controller.focusIn(body.el);
    });

    introAnimation(bodies, central);
  }

  // astro:page-load feuert bereits beim initialen Laden (Astro-Standard) —
  // ein zusätzlicher direkter Aufruf würde initPage() doppelt ausführen.
  document.addEventListener('astro:page-load', initPage);
</script>

<style>
  /* ── BACK-LINK zur Universum-Auswahl ────── */
  .galaxie-back-link {
    position: fixed;
    top: 68px;
    left: 24px;
    z-index: 20;
    font-family: var(--mono, monospace);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #5E5450;
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
  }
  .galaxie-back-link:hover { color: #6E5035; }

  /* ── INTRO-TEXT (unten mittig, STATE 1) ── */
  .solar-intro {
    position: absolute;
    bottom: clamp(24px, 4vh, 48px);
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
    z-index: 2;
  }

  .solar-intro p:first-child {
    font-family: var(--mono, monospace);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(110, 80, 53, 0.35);
    margin-bottom: 4px;
    max-width: none;
  }

  .solar-intro p:last-child {
    font-family: var(--mono, monospace);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: rgba(110, 80, 53, 0.28);
    max-width: none;
  }
</style>
