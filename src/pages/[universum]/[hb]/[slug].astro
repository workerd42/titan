---
export const prerender = false;

import PlanetLayout from '../../../layouts/PlanetLayout.astro';
import CTAButton from '../../../components/ui/CTAButton.astro';
import { BEREICHE, getBereich } from '../../../data/bereiche';
import { UNIVERSEN, getUniversum } from '../../../data/universen';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import '../../../styles/modules.css';

const { universum: universumId, hb, slug } = Astro.params;
const universum = getUniversum(universumId as string);
const bereich = getBereich(hb as string);
const alleThemen = await getCollection('themen');
const thema = alleThemen.find((t) => t.id === slug);

// SSR-Guard: ungültige Kombination aus Universum / Handlungsfeld / Thema → 404.
if (!universum || !bereich || !thema
    || thema.data.handlungsbereich !== bereich.id
    || bereich.universumId !== universum.id) {
  return new Response(null, { status: 404 });
}

const { Content } = await render(thema);
const themenDesBereichs = alleThemen
  .filter((t) => t.data.handlungsbereich === bereich.id)
  .sort((a, b) => a.data.order - b.data.order);
const eigenerIndex  = themenDesBereichs.findIndex((t) => t.id === thema.id);
const naechstesThema = themenDesBereichs[eigenerIndex + 1] ?? null;
const vorigesThema   = themenDesBereichs[eigenerIndex - 1] ?? null;
const base = import.meta.env.BASE_URL;
const hbBase = `${base}${universum.id}/${bereich.id}/`;
const d = thema.data;
---

<PlanetLayout
  title={d.title}
  description={d.description}
  canonicalPath={`/${universum.id}/${bereich.id}/${thema.id}/`}
  hbId={bereich.id}
  hbNummer={bereich.nummer}
  universumId={universum.id}
>
  <!-- Mitlaufender Fortschritt als grafischer Ring, unten links -->
  <div class="thema-ring" role="progressbar" aria-label="Kapitel-Fortschritt" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" title="Fortschritt in diesem Kapitel">
    <svg class="tr-svg" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="tr-track" cx="22" cy="22" r="19" fill="none"></circle>
      <circle class="tr-fill" id="thema-ring-fill" cx="22" cy="22" r="19" fill="none" transform="rotate(-90 22 22)"></circle>
    </svg>
    <span class="tr-pct" id="thema-progress-pct">0%</span>
  </div>

  {/* ── MODUS-AUSWAHL (vorangestellt, Norive-Stil) ──
      Wird beim Kapitel-Einstieg gezeigt; „Entdecken" führt zur vollen Seite,
      „Interaktive Module" springt zum Werkzeug. Nicht verfügbare Modi sind
      ausgegraut. Standardmäßig sichtbar (kein Flash), JS entlässt bei Auswahl. */}
  <div class="modus-select" id="modus-select" data-has-werkzeug={d.werkzeug ? 'true' : 'false'} data-has-begriffe={d.begriffe && d.begriffe.length > 0 ? 'true' : 'false'} hidden>
    <a class="ms-back" href={hbBase} aria-label={`Zurück zu ${bereich.titel}`}>
      <span aria-hidden="true">←</span> Zurück
    </a>
    <div class="ms-inner">
      <p class="ms-eyebrow">{bereich.titel} · {d.themengruppe}</p>
      <h1 class="ms-titel">{d.title}</h1>
      <p class="ms-lead">Wie möchtest du dieses Kapitel bearbeiten?</p>
      <div class="ms-cards">
        <button class="ms-card" data-mode="entdecken" type="button">
          <span class="ms-icon" aria-hidden="true">◉</span>
          <span class="ms-name">Entdecken</span>
          <span class="ms-desc">Alles auf einer Seite: Verstehen · Merken · Anwenden · Prüfen.</span>
        </button>
        <button class="ms-card" data-mode="module" data-needs="werkzeug" type="button">
          <span class="ms-icon" aria-hidden="true">◆</span>
          <span class="ms-name">Interaktive Module</span>
          <span class="ms-desc">Werkzeuge zum Anwenden auf deine Star-Company.</span>
        </button>
        <button class="ms-card" data-mode="uebung" type="button" disabled>
          <span class="ms-icon" aria-hidden="true">✎</span>
          <span class="ms-name">Übungsbereich</span>
          <span class="ms-desc">Fallaufgaben & Multiple-Choice. <em class="ms-soon">bald</em></span>
        </button>
        <button class="ms-card" data-mode="ihk" type="button" disabled>
          <span class="ms-icon" aria-hidden="true">◎</span>
          <span class="ms-name">IHK-Test-Format</span>
          <span class="ms-desc">Prüfung im Original-Format. <em class="ms-soon">bald</em></span>
        </button>
        <button class="ms-card" data-mode="lernzettel" type="button" disabled>
          <span class="ms-icon" aria-hidden="true">▤</span>
          <span class="ms-name">Lernzettel</span>
          <span class="ms-desc">Karteikarten mit den Schlüsselbegriffen. <em class="ms-soon">bald</em></span>
        </button>
      </div>
    </div>
  </div>

  <div class="thema-wrap" data-thema-slug={thema.id} data-wiederholung-tage={d.wiederholungTage}>

    <!-- ╔══ KOPF ══════════════════════════════╗ -->
    <header class="thema-kopf">
      <nav class="thema-breadcrumb" aria-label="Seitenposition">
        <a href={hbBase}>{bereich.titel}</a>
        <span aria-hidden="true">·</span>
        <span>{d.themengruppe}</span>
      </nav>
      <h1 class="thema-titel">{d.title}</h1>

      <button class="modus-reopen" id="modus-reopen" type="button">
        <span aria-hidden="true">↺</span> Modus wechseln
      </button>

      {/* Lese- & Barrierefreiheits-Optionen — Trigger ist die „Aa"-Aktion im
          Speed-Dial (siehe SpeedDial.astro / PlanetLayout). Modal, position:fixed,
          daher hier im Header-DOM ohne Layout-Einfluss. */}
      <div class="lese-modal" id="lese-modal" role="dialog" aria-modal="true" aria-label="Lesen und Barrierefreiheit" hidden>
        <div class="lm-box">
          <button class="lm-close" id="lese-close" type="button" aria-label="Schließen">×</button>
          <p class="lm-title">Lesen &amp; Barrierefreiheit</p>
          <p class="lm-sub">Gilt für alle vier Phasen · wird gespeichert</p>
          <div class="lese-row">
            <span class="lese-label" id="lese-l1">Lesemodus</span>
            <div class="lese-opts" role="group" aria-labelledby="lese-l1">
              <button class="lese-opt" data-set="lesemodus" data-val="true"  type="button">an</button>
              <button class="lese-opt" data-set="lesemodus" data-val="false" type="button">aus</button>
            </div>
          </div>
          <div class="lese-row">
            <span class="lese-label" id="lese-l2">Schriftgröße</span>
            <div class="lese-opts" role="group" aria-labelledby="lese-l2">
              <button class="lese-opt" data-set="groesse" data-val="klein"  type="button" aria-label="Klein">A−</button>
              <button class="lese-opt" data-set="groesse" data-val="normal" type="button" aria-label="Normal">A</button>
              <button class="lese-opt lese-opt--big" data-set="groesse" data-val="gross" type="button" aria-label="Groß">A+</button>
            </div>
          </div>
          <div class="lese-row">
            <span class="lese-label" id="lese-l3">Zeilenabstand</span>
            <div class="lese-opts" role="group" aria-labelledby="lese-l3">
              <button class="lese-opt" data-set="abstand" data-val="normal" type="button">normal</button>
              <button class="lese-opt" data-set="abstand" data-val="weit"   type="button">weit</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Phasen-Reiseplan -->
      <div class="phasen-reise" role="list" aria-label="Lernphasen">
        {[
          { key: 'verstehen', label: 'Verstehen', num: '01', icon: '◉' },
          { key: 'merken',    label: 'Merken',    num: '02', icon: '◈' },
          { key: 'anwenden',  label: 'Anwenden',  num: '03', icon: '◆' },
          { key: 'pruefen',   label: 'Prüfen',    num: '04', icon: '◎' },
        ].map(({ key, label, num, icon }) => (
          <a href={`#phase-${key}`} class="phase-schritt" data-phase-label={key} data-done="false" role="listitem" aria-label={`Zu Phase ${num}: ${label}`}>
            <span class="ps-icon" aria-hidden="true">{icon}</span>
            <span class="ps-num" aria-hidden="true">{num}</span>
            <span class="ps-label">{label}</span>
          </a>
        ))}
      </div>
    </header>

    <!-- ╔══ PHASE 1: VERSTEHEN ═══════════════╗ -->
    <section class="lern-phase phase-verstehen" id="phase-verstehen" aria-labelledby="h-verstehen">
      <div class="phase-banner">
        <div class="phase-banner-inner">
          <span class="phase-banner-icon" aria-hidden="true">◉</span>
          <div>
            <p class="phase-banner-num">Phase 01</p>
            <h2 id="h-verstehen" class="phase-banner-title">Verstehen</h2>
            <p class="phase-banner-hint">Lies den Inhalt aufmerksam. Nimm dir Zeit — hier entsteht die Grundlage für alles weitere.</p>
          </div>
        </div>
        <span class="phase-done-badge" data-phase-badge="verstehen" aria-hidden="true">✓ Abgeschlossen</span>
      </div>

      <!-- Wissensbibliothek -->
      <div class="kb-container">
        <!-- Haupterklärung -->
        <div class="prose kb-erklaerung">
          <Content />
        </div>

        <!-- Definitionen -->
        {d.definitionen && d.definitionen.length > 0 && (
          <div class="kb-block kb-block--definitionen">
            <h3 class="kb-block-title">
              <span aria-hidden="true">▸</span> Begriffe & Definitionen
            </h3>
            <dl class="def-liste">
              {d.definitionen.map((def) => (
                <>
                  <dt class="def-term">{def.begriff}</dt>
                  <dd class="def-text">{def.definition}</dd>
                </>
              ))}
            </dl>
          </div>
        )}

        <!-- Formeln -->
        {d.formeln && d.formeln.length > 0 && (
          <div class="kb-block kb-block--formeln">
            <h3 class="kb-block-title">
              <span aria-hidden="true">∑</span> Formelsammlung
            </h3>
            <div class="formel-stack">
              {d.formeln.map((f) => (
                <div class="formel-karte">
                  <p class="formel-name">{f.name}</p>
                  <div class="formel-display">{f.formel}</div>
                  <p class="formel-erkl">{f.erklaerung}</p>
                  {f.einheit && <p class="formel-einheit">Einheit: {f.einheit}</p>}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Rechenweg -->
        {d.rechenbeispiel && (
          <div class="kb-block kb-block--rechenweg">
            <h3 class="kb-block-title">
              <span aria-hidden="true">⟹</span> Rechenweg Schritt für Schritt
            </h3>
            <div class="rw-aufgabe">
              <p class="rw-aufgabe-label">Aufgabe</p>
              <p>{d.rechenbeispiel.aufgabe}</p>
            </div>
            <ol class="rw-schritte" aria-label="Lösungsschritte">
              {d.rechenbeispiel.schritte.map((s) => (
                <li class="rw-schritt">
                  <span class="rw-n" aria-hidden="true">{s.schritt}</span>
                  <div class="rw-body">
                    <p class="rw-beschr">{s.beschreibung}</p>
                    {s.berechnung && <div class="rw-rechnung">{s.berechnung}</div>}
                    {s.ergebnis && <p class="rw-ergebnis">{s.ergebnis}</p>}
                  </div>
                </li>
              ))}
            </ol>
            {d.rechenbeispiel.fazit && (
              <div class="rw-fazit">
                <p class="rw-fazit-label">Fazit</p>
                <p>{d.rechenbeispiel.fazit}</p>
              </div>
            )}
          </div>
        )}

        <!-- Zusammenfassung -->
        {d.zusammenfassung && d.zusammenfassung.length > 0 && (
          <div class="kb-block kb-block--zusammenfassung">
            <h3 class="kb-block-title">
              <span aria-hidden="true">✓</span> Das Wichtigste auf einen Blick
            </h3>
            <ul class="zf-liste">
              {d.zusammenfassung.map((p) => <li class="zf-punkt">{p}</li>)}
            </ul>
          </div>
        )}

        <!-- Rechtsgrundlagen — Gesetzes-Erklärer: eigene Erklärung + Anwendung
             + Link zur amtlichen Quelle (kein verbatim Gesetzestext). Native
             <details>: zero-JS, tastaturbedienbar. -->
        {d.gesetze && d.gesetze.length > 0 && (
          <div class="kb-block kb-block--gesetze">
            <h3 class="kb-block-title">
              <span aria-hidden="true">§</span> Rechtsgrundlagen
            </h3>
            <p class="ge-hinweis">Eigene Erklärung &amp; Anwendungsbeispiel — der amtliche Gesetzestext ist jeweils verlinkt.</p>
            <div class="ge-stack">
              {d.gesetze.map((g) => (
                <details class="ge-karte">
                  <summary class="ge-summary">
                    <span class="ge-norm">{g.norm}</span>
                    <span class="ge-titel">{g.titel}</span>
                  </summary>
                  <div class="ge-body">
                    <p class="ge-label">Worum es geht</p>
                    <p class="ge-text">{g.erklaerung}</p>
                    <p class="ge-label">Im Prüfungskontext</p>
                    <p class="ge-text">{g.anwendung}</p>
                    <a class="ge-quelle" href={g.quelle} target="_blank" rel="noopener noreferrer">
                      Amtlicher Gesetzestext <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                </details>
              ))}
            </div>
          </div>
        )}

        <!-- Strukturierter Inhalt-Hinweis wenn keine erweiterte Bibliothek -->
        {!d.formeln && !d.definitionen && !d.rechenbeispiel && !d.zusammenfassung && !d.gesetze && (
          <div class="kb-hinweis">
            <p class="kb-hinweis-title">Prüfungsrelevante Inhalte</p>
            <p class="kb-hinweis-text">
              Die Kernaussagen dieses Themas findest du in der Erklärung oben sowie im
              Merksatz, Fallbeispiel und der IHK-Prüfungsfrage in den Phasen unten.
              Detaillierte Formeln, Definitionen und Rechenwege werden schrittweise ergänzt.
            </p>
          </div>
        )}
      </div>

      <!-- Phase abschließen -->
      <div class="phase-abschluss">
        <button class="phase-fertig-btn" data-action="verstehen-bestaetigen">
          <span class="pfb-icon" aria-hidden="true">◉</span>
          <span class="pfb-text">Ich habe den Inhalt verstanden</span>
          <span class="pfb-arrow" aria-hidden="true">→</span>
        </button>
        <a href="#phase-merken" class="phase-weiter-link" aria-label="Weiter zu Phase Merken">
          Weiter zu Merken ↓
        </a>
      </div>
    </section>

    <!-- ╔══ PHASE 2: MERKEN ══════════════════╗ -->
    <section class="lern-phase phase-merken" id="phase-merken" aria-labelledby="h-merken">
      <div class="phase-banner">
        <div class="phase-banner-inner">
          <span class="phase-banner-icon" aria-hidden="true">◈</span>
          <div>
            <p class="phase-banner-num">Phase 02</p>
            <h2 id="h-merken" class="phase-banner-title">Merken</h2>
            <p class="phase-banner-hint">Lerne diesen Satz auswendig. Er ist dein Anker für die Prüfung.</p>
          </div>
        </div>
        <span class="phase-done-badge" data-phase-badge="merken" aria-hidden="true">✓ Abgeschlossen</span>
      </div>

      <div class="merksatz-container">
        <blockquote class="merksatz" aria-label="Merksatz">
          <span class="merksatz-anfuehrung" aria-hidden="true">„</span>
          <span class="merksatz-text">{d.merksatz}</span>
          <span class="merksatz-anfuehrung merksatz-anfuehrung--end" aria-hidden="true">"</span>
        </blockquote>

        <div class="merksatz-hilfe">
          <p class="merksatz-hilfe-text">Tipps zum Merken: Laut aussprechen, mit eigenen Worten umformulieren, oder in Stichworten notieren.</p>
        </div>
      </div>

      <div class="phase-abschluss">
        <button class="phase-fertig-btn" data-action="merken-bestaetigen">
          <span class="pfb-icon" aria-hidden="true">◈</span>
          <span class="pfb-text">Ich kann den Merksatz wiedergeben</span>
          <span class="pfb-arrow" aria-hidden="true">→</span>
        </button>
        <a href="#phase-anwenden" class="phase-weiter-link">Weiter zu Anwenden ↓</a>
      </div>
    </section>

    <!-- ╔══ PHASE 3: ANWENDEN ════════════════╗ -->
    <section class="lern-phase phase-anwenden" id="phase-anwenden" aria-labelledby="h-anwenden">
      <div class="phase-banner">
        <div class="phase-banner-inner">
          <span class="phase-banner-icon" aria-hidden="true">◆</span>
          <div>
            <p class="phase-banner-num">Phase 03</p>
            <h2 id="h-anwenden" class="phase-banner-title">Anwenden</h2>
            <p class="phase-banner-hint">Übertrage das Gelernte auf eine realistische Situation. Schreibe deine Lösung auf, bevor du die Musterlösung ansiehst.</p>
          </div>
        </div>
        <span class="phase-done-badge" data-phase-badge="anwenden" aria-hidden="true">✓ Abgeschlossen</span>
      </div>

      <!-- Kompass-Kontext (wenn vorhanden) -->
      <div class="kompass-kontext" id="kompass-kontext" hidden>
        <p class="kk-label" aria-hidden="true">◆ Deine Star-Company</p>
        <p class="kk-text" id="kk-text">Dieses Fallbeispiel bezieht sich auf dein Unternehmen.</p>
      </div>

      <!-- Fallbeispiel -->
      <div class="fallbeispiel-block">
        <div class="fb-header">
          <span class="fb-icon" aria-hidden="true">⬡</span>
          <p class="fb-label">Fallbeispiel</p>
        </div>
        <div class="fb-body">
          <p class="fb-situation" id="fb-situation-text">{d.fallbeispiel.situation}</p>
          <div class="fb-aufgabe-wrap">
            <p class="fb-aufgabe-label">Aufgabe</p>
            <p>{d.fallbeispiel.aufgabe}</p>
          </div>
        </div>
      </div>

      {d.werkzeug && (
        <div class="modul-block">
          <p class="modul-block-label">Interaktives Werkzeug</p>
          <div id="modul-mount" data-werkzeug={d.werkzeug} data-slug={thema.id}></div>
        </div>
      )}

      {/* Freies Textfeld nur, wenn kein interaktives Werkzeug hinterlegt ist */}
      {!d.werkzeug && (
        <div class="antwort-bereich">
          <label class="antwort-label" for={`antwort-${thema.id}`}>
            <span class="antwort-label-icon" aria-hidden="true">✏</span>
            Deine Lösung
          </label>
          <textarea
            id={`antwort-${thema.id}`}
            class="antwort-textarea"
            data-action="eigene-einschaetzung"
            placeholder="Schreibe hier deine Lösung — in vollständigen Sätzen, so wie in der echten Prüfung …"
            rows="5"
          ></textarea>
        </div>
      )}

      <details class="musterlosung-details">
        <summary>Musterlösung ansehen</summary>
        <div class="ml-inhalt">
          <p>{d.fallbeispiel.musterloesung}</p>
        </div>
      </details>

      <div class="phase-abschluss">
        {!d.werkzeug && (
          <button class="phase-fertig-btn" data-action="anwenden-bestaetigen">
            <span class="pfb-icon" aria-hidden="true">◆</span>
            <span class="pfb-text">Lösung mit Muster verglichen — weiter</span>
            <span class="pfb-arrow" aria-hidden="true">→</span>
          </button>
        )}
        <a href="#phase-pruefen" class="phase-weiter-link">Weiter zu Prüfen ↓</a>
      </div>
    </section>

    <!-- ╔══ PHASE 4: PRÜFEN ══════════════════╗ -->
    <section class="lern-phase phase-pruefen" id="phase-pruefen" aria-labelledby="h-pruefen">
      <div class="phase-banner">
        <div class="phase-banner-inner">
          <span class="phase-banner-icon" aria-hidden="true">◎</span>
          <div>
            <p class="phase-banner-num">Phase 04</p>
            <h2 id="h-pruefen" class="phase-banner-title">Prüfen</h2>
            <p class="phase-banner-hint">Echte IHK-Prüfungsfrage. Beantworte sie schriftlich, dann prüfe deinen Lösungsweg.</p>
          </div>
        </div>
        <span class="phase-done-badge" data-phase-badge="pruefen" aria-hidden="true">✓ Abgeschlossen</span>
      </div>

      <!-- Prüfungsfrage im Prüfungsmodus -->
      <div class="pruefungs-modus">
        <div class="pm-header">
          <span class="pm-badge">IHK-Format</span>
          <p class="pm-hint">Wie in der echten schriftlichen Prüfung</p>
        </div>
        <div class="pm-frage">
          <p>{d.pruefungsfrage.frage}</p>
        </div>
      </div>

      <details class="musterlosung-details">
        <summary>Lösungsweg ansehen</summary>
        <div class="ml-inhalt">
          <ol class="lw-liste">
            {d.pruefungsfrage.loesungsweg.map((s) => <li>{s}</li>)}
          </ol>
        </div>
      </details>

      <!-- Selbsteinschätzung -->
      <div class="selbsteinschaetzung" role="group" aria-label="Wie gut hast du abgeschnitten?">
        <p class="se-frage">Wie lief es?</p>
        <div class="se-btns">
          <button class="se-btn se-btn--gut" data-action="pruefen-einschaetzung" data-wert="geloest">
            <span aria-hidden="true">✓</span> Konnte ich lösen
          </button>
          <button class="se-btn se-btn--wiederholen" data-action="pruefen-einschaetzung" data-wert="wiederholen">
            <span aria-hidden="true">↻</span> Muss ich wiederholen
          </button>
        </div>
        <p class="se-info" data-wiederholung-hinweis aria-live="polite">
          Deine Einschätzung entscheidet, ob dieses Thema in {d.wiederholungTage} Tagen erneut vorgeschlagen wird.
        </p>
      </div>
    </section>

    {/* ╔══ LERNZETTEL (Karteikarten, optional) ══╗ */}
    {d.begriffe && d.begriffe.length > 0 && (
      <section class="lern-phase lernzettel-section" id="lernzettel" aria-labelledby="h-lernzettel">
        <div class="phase-banner">
          <div class="phase-banner-inner">
            <span class="phase-banner-icon" aria-hidden="true">▤</span>
            <div>
              <p class="phase-banner-num">Lernzettel</p>
              <h2 id="h-lernzettel" class="phase-banner-title">Schlüsselbegriffe</h2>
              <p class="phase-banner-hint">Tippe eine Karte, um die Auflösung zu sehen — ideal zum schnellen Wiederholen.</p>
            </div>
          </div>
        </div>
        <div class="lz-grid">
          {d.begriffe.map((b) => (
            <button class="lz-card" type="button" aria-label={`${b.begriff} — Auflösung anzeigen`}>
              <span class="lz-inner">
                <span class="lz-face lz-front">
                  <span class="lz-begriff">{b.begriff}</span>
                  <span class="lz-flip-hint" aria-hidden="true">tippen zum Umdrehen</span>
                </span>
                <span class="lz-face lz-back">
                  {b.aufloesung && <span class="lz-aufloesung">{b.aufloesung}</span>}
                  <span class="lz-erklaerung">{b.erklaerung}</span>
                </span>
              </span>
            </button>
          ))}
        </div>
      </section>
    )}

    <!-- ╔══ NAVIGATION ═══════════════════════╗ -->
    <nav class="thema-nav" aria-label="Zwischen Themen wechseln">
      <div>
        {vorigesThema ? (
          <CTAButton href={`${hbBase}${vorigesThema.id}/`} variant="back">
            {vorigesThema.data.title}
          </CTAButton>
        ) : (
          <CTAButton href={hbBase} variant="back">Zurück zur Übersicht</CTAButton>
        )}
      </div>
      <div>
        {naechstesThema ? (
          <CTAButton href={`${hbBase}${naechstesThema.id}/`} variant="light">
            {naechstesThema.data.title}
          </CTAButton>
        ) : (
          <CTAButton href={hbBase} variant="light">Zurück zur Übersicht</CTAButton>
        )}
      </div>
    </nav>

  </div>
</PlanetLayout>

<script>
  // ── PHASEN-SIDEBAR: Scroll-Verhalten (funktioniert auf ALLEN Planeten) ──────
  // Scroll-basiert statt IntersectionObserver — zuverlässiger mit Astro ClientRouter

  function initPhaseSidebar(): (() => void) | void {
    const phasenReise = document.querySelector<HTMLElement>('.phasen-reise');
    const themaKopf   = document.querySelector<HTMLElement>('.thema-kopf');
    const lernPhasen  = document.querySelectorAll<HTMLElement>('.lern-phase');

    if (!phasenReise || !themaKopf) return;

    let active = false;

    const check = () => {
      const rect   = themaKopf.getBoundingClientRect();
      const should = rect.bottom < 72; // Aktiviert wenn Header-Unterkante 72px über Top

      if (should === active) return; // Kein Flackern
      active = should;

      phasenReise.classList.toggle('sidebar-mode', should);
      lernPhasen.forEach(p => p.classList.toggle('sidebar-active', should));
    };

    // Scroll-Listener + initialer Check
    window.addEventListener('scroll', check, { passive: true });
    check();

    // Cleanup-Funktion zurückgeben
    return () => window.removeEventListener('scroll', check);
  }

  // Sofort ausführen (initaler Seitenaufruf)
  let cleanup = initPhaseSidebar();

  // Bei ClientRouter-Navigation: neu initialisieren
  document.addEventListener('astro:page-load', () => {
    cleanup?.();
    cleanup = initPhaseSidebar();
  });
</script>

<!-- Lese- & Barrierefreiheits-Optionen: Zustand global gespeichert, gilt für alle vier Phasen -->
<script>
  const LESE_KEY = 'titan-lese-v1';
  const LESE_DEFAULT = { lesemodus: 'false', groesse: 'normal', abstand: 'normal' };

  function leseLoad(): Record<string, string> {
    try { return { ...LESE_DEFAULT, ...JSON.parse(localStorage.getItem(LESE_KEY) || '{}') }; }
    catch { return { ...LESE_DEFAULT }; }
  }
  function leseApply(s: Record<string, string>): void {
    const wrap = document.querySelector<HTMLElement>('.thema-wrap');
    if (!wrap) return;
    wrap.dataset.lesemodus = s.lesemodus;
    wrap.dataset.groesse = s.groesse;
    wrap.dataset.abstand = s.abstand;
    document.querySelectorAll<HTMLElement>('.lese-opt').forEach((b) => {
      b.setAttribute('aria-pressed', String(s[b.dataset.set ?? ''] === b.dataset.val));
    });
  }
  function initLese(): void {
    const wrap = document.querySelector<HTMLElement>('.thema-wrap');
    if (!wrap) return;
    const s = leseLoad();
    leseApply(s);
    const toggle = document.getElementById('lese-toggle');   // „Aa" im Speed-Dial
    const modal = document.getElementById('lese-modal');
    const setOpen = (open: boolean) => {
      if (open) modal?.removeAttribute('hidden'); else modal?.setAttribute('hidden', '');
      toggle?.setAttribute('aria-expanded', String(open));
    };
    toggle?.addEventListener('click', () => setOpen(true));
    document.getElementById('lese-close')?.addEventListener('click', () => setOpen(false));
    modal?.addEventListener('click', (e) => { if (e.target === modal) setOpen(false); });
    document.querySelectorAll<HTMLElement>('.lese-opt').forEach((b) => {
      b.addEventListener('click', () => {
        const key = b.dataset.set; const val = b.dataset.val;
        if (!key || val == null) return;
        s[key] = val;
        try { localStorage.setItem(LESE_KEY, JSON.stringify(s)); } catch { /* voll/blockiert */ }
        leseApply(s);
      });
    });
  }
  document.addEventListener('astro:page-load', initLese);
  if (document.readyState !== 'loading') initLese();
  else document.addEventListener('DOMContentLoaded', initLese);

  // ESC schließt das Lese-Modal (einmalig, überlebt Navigation)
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const modal = document.getElementById('lese-modal');
    if (modal && !modal.hasAttribute('hidden')) {
      modal.setAttribute('hidden', '');
      document.getElementById('lese-toggle')?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<!-- Kompass-Integration: {{platzhalter}} im ganzen Inhalt ersetzen + Kontext-Hinweis -->
<script>
  import { substituteDom, readKompass, firmaName, hasKompass } from '../../../scripts/kompass-vars';

  const BRANCHE: Record<string, string> = {
    handel: 'Handel', industrie: 'Industrie', dienstleistung: 'Dienstleistung',
    handwerk: 'Handwerk', sonstiges: 'Sonstiges',
  };

  function initKompass(): void {
    const wrap = document.querySelector<HTMLElement>('.thema-wrap');
    // 1) „Kompass überall": Platzhalter ({{firma}}, {{branche}} …) im Inhalt ersetzen.
    substituteDom(wrap ?? document.body);
    if (!hasKompass()) return;
    const k = readKompass();
    // 2) Kontext-Hinweis in Phase „Anwenden"
    const ctx = document.getElementById('kompass-kontext');
    const txt = document.getElementById('kk-text');
    if (ctx && txt) {
      ctx.hidden = false;
      const branche = k?.branche ? `(${BRANCHE[k.branche] ?? k.branche})` : '';
      const meta = [k?.rechtsform, branche].filter(Boolean).join(' ');
      txt.textContent = `Denke beim Lösen an dein Unternehmen: ${firmaName()}${meta ? ' — ' + meta : ''}`;
    }
    // 3) Notiz am Fallbeispiel (nur einmal anhängen — läuft auch bei Navigation)
    const sitEl = document.getElementById('fb-situation-text');
    if (sitEl && !sitEl.parentElement?.querySelector('.fb-kompass-hinweis')) {
      const hinweis = document.createElement('p');
      hinweis.className = 'fb-kompass-hinweis';
      hinweis.innerHTML = `<small>💡 Beziehe diese Aufgabe gedanklich auf <strong>${firmaName()}</strong>.</small>`;
      sitEl.parentElement?.appendChild(hinweis);
    }
  }

  document.addEventListener('astro:page-load', initKompass);
  if (document.readyState !== 'loading') initKompass();
  else document.addEventListener('DOMContentLoaded', initKompass);
</script>

<!-- Modus-Auswahl: vorangestellte „Wie bearbeiten?"-Wahl -->
<script>
  const MODUS_KEY = 'titan-modus-v1';
  function applyModus(mode: string): void {
    // „entdecken" = volle Seite (nichts weiter). Andere Modi springen zum Ziel.
    const targetId = mode === 'module' ? 'phase-anwenden' : mode === 'lernzettel' ? 'lernzettel' : '';
    if (targetId) {
      window.setTimeout(() => document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 120);
    }
  }
  function initModusSelect(): void {
    const ov = document.getElementById('modus-select');
    if (!ov || ov.dataset.done === 'true') return;
    ov.dataset.done = 'true';

    const moduleAvail = ov.dataset.hasWerkzeug === 'true';
    if (!moduleAvail) {
      const m = ov.querySelector<HTMLButtonElement>('.ms-card[data-mode="module"]');
      if (m) {
        m.disabled = true;
        const d = m.querySelector('.ms-desc');
        if (d) d.innerHTML = 'Für dieses Kapitel (noch) kein interaktives Werkzeug. <em class="ms-soon">bald</em>';
      }
    }
    const begriffeAvail = ov.dataset.hasBegriffe === 'true';
    if (begriffeAvail) {
      const lz = ov.querySelector<HTMLButtonElement>('.ms-card[data-mode="lernzettel"]');
      if (lz) { lz.disabled = false; const d = lz.querySelector('.ms-desc'); if (d) d.textContent = 'Karteikarten mit den Schlüsselbegriffen.'; }
    }
    const verfuegbar = (m: string) => m === 'module' ? moduleAvail : m === 'lernzettel' ? begriffeAvail : m === 'entdecken';

    const open = () => { ov.removeAttribute('hidden'); ov.classList.remove('is-gone'); document.body.style.overflow = 'hidden'; };
    const close = (animate = true) => {
      document.body.style.overflow = '';
      if (animate) { ov.classList.add('is-gone'); window.setTimeout(() => ov.setAttribute('hidden', ''), 360); }
      else ov.setAttribute('hidden', '');
    };

    // Gemerkte Auswahl → Screen überspringen (außer „module" ohne Werkzeug)
    let remembered: string | null = null;
    try { remembered = localStorage.getItem(MODUS_KEY); } catch { /* blockiert */ }
    if (remembered && verfuegbar(remembered)) { close(false); applyModus(remembered); }
    else open();

    ov.querySelectorAll<HTMLButtonElement>('.ms-card').forEach((c) => {
      if (c.disabled) return;
      c.addEventListener('click', () => {
        const mode = c.dataset.mode ?? 'entdecken';
        try { localStorage.setItem(MODUS_KEY, mode); } catch { /* blockiert */ }
        close();
        applyModus(mode);
      });
    });
    // Hintergrund-Klick → Standard „Entdecken" (wird gemerkt)
    ov.addEventListener('click', (e) => {
      if (e.target !== ov) return;
      try { localStorage.setItem(MODUS_KEY, 'entdecken'); } catch { /* blockiert */ }
      close();
    });
    // „Modus wechseln" im Kopf öffnet den Screen erneut
    document.getElementById('modus-reopen')?.addEventListener('click', open);
  }
  document.addEventListener('astro:page-load', initModusSelect);
  if (document.readyState !== 'loading') initModusSelect();
  else document.addEventListener('DOMContentLoaded', initModusSelect);
  // ESC schließt den offenen Modus-Screen (einmalig)
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const ov = document.getElementById('modus-select');
    if (ov && !ov.hasAttribute('hidden')) {
      document.body.style.overflow = '';
      ov.classList.add('is-gone');
      window.setTimeout(() => ov.setAttribute('hidden', ''), 360);
    }
  });
</script>

<!-- Lernzettel: Karteikarten umdrehen -->
<script>
  function initLernzettel(): void {
    document.querySelectorAll<HTMLButtonElement>('.lz-card').forEach((card) => {
      if (card.dataset.wired === 'true') return;
      card.dataset.wired = 'true';
      card.addEventListener('click', () => {
        const flipped = card.classList.toggle('is-flipped');
        card.setAttribute('aria-pressed', String(flipped));
      });
    });
  }
  document.addEventListener('astro:page-load', initLernzettel);
  if (document.readyState !== 'loading') initLernzettel();
  else document.addEventListener('DOMContentLoaded', initLernzettel);
</script>

