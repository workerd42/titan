  .thema-wrap[data-groesse="klein"] .prose { font-size: 0.9em; }
  .thema-wrap[data-abstand="weit"] .prose { line-height: 2.05; }
  .thema-wrap[data-abstand="weit"] .prose p { margin-bottom: 1.4em; }

  /* Lesemodus: ablenkungsfrei — Navigations-Chrome aus, komfortablerer Satz;
     Interaktions-Elemente (Werkzeuge, Buttons) bleiben nutzbar. */
  .thema-wrap[data-lesemodus="true"] .phasen-reise { display: none; }
  .thema-wrap[data-lesemodus="true"] .phase-done-badge { display: none; }
  .thema-wrap[data-lesemodus="true"] .prose { font-size: 1.1em; line-height: 1.95; }
  @media (prefers-reduced-motion: reduce) { .thema-progress-fill { transition: none; } }

  /* ── PHASEN-REISEPLAN ───────────────────────── */
  .phasen-reise {
    display: flex;
    gap: 0;
    border: 1px solid var(--border);
    overflow: hidden;
    border-radius: 2px;
    transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  /* ── SCROLL-SIDEBAR-MODUS ──────────────────── */
  /* Wenn Nutzer nach unten scrollt, wandern die Phasen als
     vertikale Sidebar an den linken Rand */
  .phasen-reise.sidebar-mode {
    position: fixed;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    flex-direction: column;
    border: none;
    border-right: 1px solid var(--border);
    border-radius: 0;
    background: var(--bg, #EDE8DF);
    z-index: 30;
    gap: 0;
    width: 52px;
    overflow: visible;
    box-shadow: 2px 0 12px rgba(28,25,23,0.06);
  }

  /* KEIN Content-Shift mehr: Der Inhalt bleibt zentriert (max-width + margin auto),
     die fixierte Sidebar schwebt in der linken Randspalte. Früher schob ein
     padding-left den zentrierten Inhalt nach rechts → Sprung beim Scrollen +
     gebrochene Zentrierung. Die .sidebar-active-Klasse bleibt (JS-Hook), wirkt
     aber bewusst nicht mehr auf die Ausrichtung. */

  /* Auf schmalen Schirmen ist die Randspalte zu klein für die 52px-Sidebar
     (sie würde den Text überlappen) → dort ausblenden. Die Phasenleiste oben
     bleibt zur Navigation erhalten. */
  @media (max-width: 1000px) {
    .phasen-reise.sidebar-mode { display: none; }
  }

  .phase-schritt {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: var(--sp-sm) var(--sp-xs);
    border-right: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-muted);
    background: transparent;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
    position: relative;
  }

  /* Sidebar-Modus: quadratische Icons statt Leiste */
  .sidebar-mode .phase-schritt {
    flex: none;
    width: 52px;
    height: 52px;
    padding: 0;
    border-right: none;
    border-bottom: 1px solid var(--border);
    justify-content: center;
  }

  .sidebar-mode .ps-num,
  .sidebar-mode .ps-label { display: none; }

  .sidebar-mode .ps-icon { font-size: 18px; }

  .phase-schritt:last-child { border-right: none; }

  .phase-schritt:hover {
    background: var(--accent-soft);
    color: var(--accent);
    text-decoration: none;
  }

  .phase-schritt[data-done="true"] {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .phase-schritt[data-done="true"]::after {
    content: '✓';
    position: absolute;
    top: 4px;
    right: 6px;
    font-size: 9px;
    color: var(--accent);
  }

  .ps-icon {
    font-size: 16px;
    line-height: 1;
    color: var(--accent);
    opacity: 0.4;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .phase-schritt[data-done="true"] .ps-icon,
  .phase-schritt:hover .ps-icon { opacity: 1; }

  .ps-num {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    color: inherit;
  }

  .ps-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: inherit;
    display: none;
  }

  @media (min-width: 480px) { .ps-label { display: block; } }

  /* ── LERN-PHASE ─────────────────────────────── */
  .lern-phase {
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 100px;
  }

  /* ── PHASE-BANNER ───────────────────────────── */
  .phase-banner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-md);
    padding: var(--sp-xl) var(--sp-lg);
    max-width: var(--max-read);
    margin: 0 auto;
  }

  /* Icon hängt in die linke Randspalte, damit der Banner-Text bündig zum
     Fließtext (.kb-container etc.) steht — nicht um Icon+Abstand eingerückt. */
  .phase-banner-inner {
    position: relative;
  }

  .phase-banner-icon {
    position: absolute;
    left: -40px;
    top: 2px;
    font-size: 28px;
    line-height: 1;
  }

  /* Phasen-Farbidentitäten */
  .phase-verstehen .phase-banner-icon { color: #6E7EA0; }
  .phase-merken    .phase-banner-icon { color: var(--accent); }
  .phase-anwenden  .phase-banner-icon { color: #5A8A6A; }
  .phase-pruefen   .phase-banner-icon { color: #8A7650; }

  .phase-banner-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
    max-width: none;
  }

  .phase-banner-title {
    font-family: var(--mono);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 400;
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-sm);
  }

  /* Phasen-Titelfarben */
  .phase-verstehen .phase-banner-title { color: #6E7EA0; }
  .phase-merken    .phase-banner-title { color: var(--accent); }
  .phase-anwenden  .phase-banner-title { color: #5A8A6A; }
  .phase-pruefen   .phase-banner-title { color: #8A7650; }

  .phase-banner-hint {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 460px;
  }

  .phase-done-badge {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 10px;
    border: 1px solid var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
    display: none;
  }

  [data-phase-badge][data-visible="true"] { display: block; }

  /* ── WISSENSBIBLIOTHEK ──────────────────────── */
  .kb-container {
    padding: 0 var(--sp-lg) var(--sp-xl);
    max-width: var(--max-read);
    margin: 0 auto;
  }

  .kb-erklaerung { margin-bottom: var(--sp-xl); }

  .kb-block {
    margin: var(--sp-xl) 0;
    padding: var(--sp-lg);
    border-left: 3px solid var(--border-mid);
  }

  .kb-block--definitionen { border-left-color: #6E7EA0; }
  .kb-block--formeln      { border-left-color: var(--text-muted); }
  .kb-block--rechenweg    { border-left-color: var(--text); }
  .kb-block--zusammenfassung { border-left-color: var(--accent); background: var(--accent-soft); }
  .kb-block--gesetze      { border-left-color: var(--accent); }

  /* Rechtsgrundlagen — ausklappbare §-Karten (native <details>) */
  .ge-hinweis {
    font-family: var(--mono); font-size: 12px; line-height: 1.6;
    color: var(--text-muted); margin-bottom: var(--sp-md); max-width: var(--max-read);
  }
  .ge-stack { display: flex; flex-direction: column; gap: var(--sp-sm); }
  .ge-karte {
    border: 1px solid var(--border-mid); border-radius: 4px;
    background: var(--bg-alt); overflow: hidden;
  }
  .ge-summary {
    display: flex; align-items: center; gap: var(--sp-sm);
    padding: var(--sp-md) var(--sp-lg); min-height: 44px;
    cursor: pointer; list-style: none; user-select: none;
    transition: background var(--dur-fast) var(--ease);
  }
  .ge-summary:hover { background: var(--accent-soft); }
  .ge-summary:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }
  /* „+"/„×"-Marker kommt global aus planet.css (summary::before) — links, konsistent
     mit den übrigen Titan-Accordions. Er soll den Akzent-Ton tragen. */
  .ge-summary::before { color: var(--accent); }
  .ge-norm {
    font-family: var(--mono); font-size: 13px; font-weight: 400;
    color: var(--accent); white-space: nowrap;
  }
  .ge-titel {
    font-family: var(--serif); font-style: italic; font-size: 17px;
    color: var(--text); flex: 1;
  }
  .ge-body {
    padding: 0 var(--sp-lg) var(--sp-lg);
    border-top: 1px solid var(--border);
  }
  .ge-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--text-muted);
    margin: var(--sp-md) 0 4px;
  }
  .ge-text {
    font-family: var(--mono); font-size: 13px; line-height: 1.7;
    color: var(--text); max-width: var(--max-read);
  }
  .ge-quelle {
    display: inline-block; margin-top: var(--sp-md);
    font-family: var(--mono); font-size: 12px; color: var(--accent);
    text-decoration: none; border-bottom: 1px solid var(--accent-soft);
    padding-bottom: 1px; transition: border-color var(--dur-fast) var(--ease);
  }
  .ge-quelle:hover { border-bottom-color: var(--accent); }
  .ge-quelle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) {
    .ge-summary, .ge-quelle { transition: none; }
  }

  .kb-block-title {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-md);
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
  }

  /* Definitionen */
  .def-liste { display: flex; flex-direction: column; gap: var(--sp-md); }
  .def-term {
    font-family: var(--serif); font-size: 18px; font-weight: 600;
    font-style: italic; color: var(--text); margin-bottom: 2px;
  }
  .def-text {
    font-family: var(--mono); font-size: 13px; font-weight: 300;
    color: var(--text-muted); line-height: 1.7;
    padding-left: var(--sp-md); border-left: 1px solid var(--border);
    margin-bottom: var(--sp-sm); max-width: var(--max-read);
  }

  /* Formeln */
  .formel-stack { display: flex; flex-direction: column; gap: var(--sp-lg); }
  .formel-karte { background: var(--bg-alt); padding: var(--sp-lg); border: 1px solid var(--border); }
  .formel-name {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--sp-sm); max-width: none;
  }
  .formel-display {
    font-family: var(--mono); font-size: clamp(15px, 1.8vw, 20px);
    font-weight: 400; color: var(--text); background: var(--bg);
    padding: var(--sp-md) var(--sp-lg); border: 1px solid var(--border-mid);
    margin-bottom: var(--sp-sm); overflow-x: auto; white-space: nowrap;
  }
  .formel-erkl {
    font-family: var(--mono); font-size: 13px; color: var(--text-muted);
    line-height: 1.65; margin-bottom: 4px; max-width: var(--max-read);
  }
  .formel-einheit { font-family: var(--mono); font-size: 11px; color: var(--accent); opacity: 0.7; max-width: none; }

  /* Rechenweg */
  .rw-aufgabe { background: var(--bg-alt); padding: var(--sp-lg); border: 1px solid var(--border); margin-bottom: var(--sp-lg); }
  .rw-aufgabe-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--accent); margin-bottom: var(--sp-sm); max-width: none;
  }
  .rw-schritte { list-style: none; padding: 0; margin: 0; }
  .rw-schritt {
    display: grid; grid-template-columns: 36px 1fr;
    gap: var(--sp-md); padding: var(--sp-md) 0;
    border-bottom: 1px solid var(--border); align-items: start;
  }
  .rw-n {
    font-family: var(--mono); font-size: 11px; color: var(--accent);
    width: 28px; height: 28px; border: 1px solid rgba(196,168,130,0.3);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
  }
  .rw-body { display: flex; flex-direction: column; gap: var(--sp-xs); }
  .rw-beschr { font-family: var(--mono); font-size: 13px; font-weight: 400; color: var(--text); max-width: none; }
  .rw-rechnung {
    font-family: var(--mono); font-size: 14px; font-weight: 300;
    background: var(--bg-alt); padding: var(--sp-sm) var(--sp-md);
    border: 1px solid var(--border); overflow-x: auto; white-space: nowrap;
  }
  .rw-ergebnis { font-family: var(--mono); font-size: 13px; font-weight: 400; color: var(--accent); max-width: none; }
  .rw-fazit {
    margin-top: var(--sp-lg); padding: var(--sp-lg);
    background: rgba(110,80,53,0.06); border-left: 2px solid var(--accent);
  }
  .rw-fazit-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: var(--sp-sm); max-width: none; }
  .rw-fazit p { font-family: var(--mono); font-size: 13px; font-weight: 300; line-height: 1.7; color: var(--text); max-width: var(--max-read); }

  /* Zusammenfassung */
  .zf-liste { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--sp-sm); }
  .zf-punkt {
    font-family: var(--mono); font-size: 13px; font-weight: 300; line-height: 1.65;
    color: var(--text); padding-left: var(--sp-lg); position: relative;
  }
  .zf-punkt::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 12px; }

  .kb-folgt {
    font-family: var(--mono); font-size: 13px; font-style: italic;
    color: var(--text-muted); padding: var(--sp-lg); border: 1px dashed var(--border);
    max-width: var(--max-read);
  }

  .kb-hinweis {
    padding: var(--sp-lg);
    border: 1px solid var(--border);
    background: var(--bg-alt, rgba(110,80,53,0.03));
    max-width: var(--max-read);
  }

  .kb-hinweis-title {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent, #6E5035);
    margin-bottom: var(--sp-sm);
    max-width: none;
  }

  .kb-hinweis-text {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: var(--max-read);
  }

  /* ── PHASE-ABSCHLUSS ────────────────────────── */
  .phase-abschluss {
    padding: var(--sp-lg) var(--sp-lg) var(--sp-xl);
    max-width: var(--max-read);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--sp-xl);
    flex-wrap: wrap;
  }

  .phase-fertig-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-md);
    padding: 14px var(--sp-xl);
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
    min-height: 48px;
  }

  .phase-fertig-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .phase-fertig-btn[data-chosen="true"] {
    background: var(--accent);
    color: var(--bg);
    opacity: 0.65;
    pointer-events: none;
  }

  .pfb-icon { font-size: 14px; }
  .pfb-text { flex: 1; }
  .pfb-arrow { opacity: 0.5; }

  .phase-weiter-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  .phase-weiter-link:hover { color: var(--accent); }

  /* ── MERKSATZ ───────────────────────────────── */
  .merksatz-container {
    padding: var(--sp-lg) var(--sp-lg) var(--sp-md);
    max-width: var(--max-read);
    margin: 0 auto;
  }

  .merksatz {
    font-family: var(--serif);
    font-size: clamp(20px, 2.8vw, 30px);
    font-weight: 300;
    line-height: 1.5;
    color: var(--text);
    padding: var(--sp-xl);
    border: 1px solid var(--accent);
    background: rgba(110,80,53,0.04);
    position: relative;
    margin-bottom: var(--sp-md);
  }

  .merksatz-anfuehrung {
    font-size: 0.85em;
    color: var(--accent);
    opacity: 0.6;
    font-style: normal;
  }

  .merksatz-anfuehrung--end { margin-left: 2px; }

  .merksatz-text { font-style: italic; }

  .merksatz-hilfe {
    background: var(--bg-alt);
    padding: var(--sp-md);
    border: 1px solid var(--border);
  }

  .merksatz-hilfe-text {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-muted);
    max-width: none;
  }

  /* ── KOMPASS-KONTEXT ────────────────────────── */
  .kompass-kontext {
    max-width: var(--max-read);
    margin: 0 auto var(--sp-lg);
    padding: var(--sp-md) var(--sp-lg);
    background: rgba(90,138,106,0.06);
    border-left: 3px solid #5A8A6A;
    margin-left: var(--sp-lg);
    margin-right: var(--sp-lg);
  }

  .kk-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--success); margin-bottom: 4px; max-width: none;
  }

  .kk-text {
    font-family: var(--mono); font-size: 13px; font-weight: 300;
    color: var(--text); max-width: var(--max-read);
  }

  /* ── FALLBEISPIEL ───────────────────────────── */
  .fallbeispiel-block {
    max-width: var(--max-read);
    margin: 0 auto var(--sp-lg);
    padding-left: var(--sp-lg);
    padding-right: var(--sp-lg);
  }

  .fb-header {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    margin-bottom: var(--sp-md);
  }

  .fb-icon { font-size: 18px; color: var(--success-soft); }

  .fb-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--success); max-width: none;
  }

  .fb-body {
    padding: var(--sp-lg);
    border: 1px solid rgba(90,138,106,0.3);
    background: rgba(90,138,106,0.03);
  }

  .fb-situation {
    font-family: var(--mono); font-size: 14px; font-weight: 300;
    line-height: 1.75; color: var(--text);
    margin-bottom: var(--sp-md); max-width: var(--max-read);
  }

  .fb-aufgabe-wrap { border-top: 1px solid rgba(90,138,106,0.2); padding-top: var(--sp-md); }

  .fb-aufgabe-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--sp-xs); max-width: none;
  }

  .fb-kompass-hinweis {
    font-family: var(--mono); font-size: 11px; color: #5A8A6A;
    margin-top: var(--sp-sm); max-width: none;
  }

  /* ── ANTWORT-BEREICH ────────────────────────── */
  .antwort-bereich {
    max-width: var(--max-read);
    margin: 0 auto var(--sp-lg);
    padding-left: var(--sp-lg);
    padding-right: var(--sp-lg);
  }

  .antwort-label {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-sm);
  }

  .antwort-label-icon { font-size: 14px; color: #5A8A6A; }

  .antwort-textarea {
    width: 100%;
    padding: var(--sp-md);
    background: transparent;
    border: 1px solid var(--border-mid);
    border-left: 3px solid rgba(90,138,106,0.4);
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 300;
    color: var(--text);
    resize: vertical;
    line-height: 1.7;
    margin-bottom: var(--sp-md);
    transition: border-color var(--dur-fast) var(--ease);
  }

  .antwort-textarea:focus-visible {
    outline: 1.5px solid #5A8A6A;
    outline-offset: 2px;
    border-left-color: #5A8A6A;
  }

  /* ── MUSTERLÖSUNG ───────────────────────────── */
  .musterlosung-details {
    max-width: var(--max-read);
    margin: 0 auto var(--sp-lg);
    padding-left: var(--sp-lg);
    padding-right: var(--sp-lg);
    border: 1px solid var(--border);
  }

