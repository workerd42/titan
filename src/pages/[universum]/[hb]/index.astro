---
import SpaceLayout from '../../../layouts/SpaceLayout.astro';
import CarouselStageVertical from '../../../components/space/CarouselStageVertical.astro';
import CarouselCaptionSide from '../../../components/ui/CarouselCaptionSide.astro';
import Planet from '../../../components/space/Planet.astro';
import { BEREICHE, getBereich } from '../../../data/bereiche';
import { UNIVERSEN, getUniversum } from '../../../data/universen';
import { getCollection, type CollectionEntry } from 'astro:content';

export const prerender = false;

const { universum: universumId, hb } = Astro.params;
const universum = getUniversum(universumId as string);
const bereich = getBereich(hb as string);
if (!bereich || !universum) return Astro.redirect(import.meta.env.BASE_URL);

const alleThemen = await getCollection('themen');
const themen = alleThemen
  .filter(t => t.data.handlungsbereich === bereich.id)
  .sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL;
const hbBase = `${base}${universum.id}/${bereich.id}/`;

const gruppenNamen = bereich.themengruppen.map(g => g.name);

// Planetenfarben: 6 Variationen, pro Themengruppe eine
const COLORS = [
  { h: '#7AC0E8', b: '#1E2A3E', r: 'rgba(122,192,232,0.45)' },
  { h: '#E8C480', b: '#3D2B1A', r: 'rgba(232,196,128,0.45)' },
  { h: '#7AC898', b: '#1A2E20', r: 'rgba(122,200,152,0.45)' },
  { h: '#E8889A', b: '#3E1A22', r: 'rgba(232,136,154,0.45)' },
  { h: '#C880D8', b: '#2E1A3E', r: 'rgba(200,128,216,0.45)' },
  { h: '#E89860', b: '#3D2418', r: 'rgba(232,152,96,0.45)' },
];

// Flache, geordnete Liste (Gruppe, dann Reihenfolge) + Farbe pro Gruppe —
// kein Ring-/Winkel-Assignment mehr nötig (Karussell braucht nur den Index).
const themenMitIndex = (() => {
  const result: Array<{ thema: CollectionEntry<'themen'>; colorIdx: number }> = [];
  gruppenNamen.forEach((gruppe, gi) => {
    const gruppenThemen = themen.filter(t => t.data.themengruppe === gruppe);
    const colorIdx = gi % COLORS.length;
    gruppenThemen.forEach((thema) => result.push({ thema, colorIdx }));
  });
  return result;
})();
---

<SpaceLayout
  title={`HF ${bereich.nummer} — ${bereich.titel}`}
  description={`Handlungsfeld ${bereich.nummer}: ${themen.length} Kapitel zur IHK-Prüfungsvorbereitung.`}
  canonicalPath={`/${universum.id}/${bereich.id}/`}
  showSearch={true}
>
  <!-- Header -->
  <header class="ui-hdr">
    <a href={`${base}${universum.id}/`} class="uih-back-link" aria-label="Zurück zu allen Handlungsfeldern">
      ← Alle HF
    </a>
    <div class="uih-center">
      <span class="uih-nr">HF {bereich.nummer}</span>
      <span class="uih-titel">{bereich.titel}</span>
    </div>
    <span class="uih-count">{themen.length} Kapitel</span>
  </header>

  <main id="hauptinhalt" tabindex="-1">
    <CarouselStageVertical stageId="theme-stage" universumId={bereich.id} itemCount={themenMitIndex.length}>
      {themenMitIndex.map(({ thema, colorIdx }, i) => (
        <Planet
          slug={thema.id}
          hbId={bereich.id}
          titel={thema.data.title}
          gruppe={thema.data.themengruppe}
          beschreibung={thema.data.description}
          href={`${hbBase}${thema.id}/`}
          index={i}
          color={COLORS[colorIdx]}
        />
      ))}

      <CarouselCaptionSide slot="caption" />
    </CarouselStageVertical>

    <!-- Zugängliche Liste (Mobile / Screenreader / reduced-motion) -->
    <nav class="theme-list-sr" aria-label="Kapitel als Liste">
      {gruppenNamen.map((gruppe) => {
        const gt = themen.filter(t => t.data.themengruppe === gruppe);
        if (!gt.length) return null;
        return (
          <div class="tls-gruppe">
            <p class="tls-gruppe-titel">{gruppe}</p>
            {gt.map(t => (
              <a href={`${hbBase}${t.id}/`} class="tls-item">
                {t.data.title}
              </a>
            ))}
          </div>
        );
      })}
    </nav>
  </main>
</SpaceLayout>

<script src="../../../scripts/norive-progress.ts"></script>
<script>
  import { initCarousel, responsivePlanetSize, type CarouselController } from '../../../scripts/gsap-carousel';
  import { createCaptionSync, type CaptionSync } from '../../../scripts/carousel-caption';
  import { initFocusView, openFocus } from '../../../scripts/focus-view';
  import { gsap } from 'gsap';

  const BASE_SIZES = [125, 140, 110, 130, 115, 125, 105, 140, 115];

  let controller: CarouselController | null = null;
  let caption: CaptionSync | null = null;

  function initPage(): void {
    const stage = document.getElementById('theme-stage');
    const track = document.getElementById('theme-stage-track');
    if (!stage || !track) return;

    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement | null;
    if (canvas) canvas.style.display = '';
    const wordmark = document.querySelector<HTMLElement>('.norive-wordmark');
    const nav      = document.querySelector<HTMLElement>('.space-nav');
    if (wordmark) wordmark.style.color = '#C4A882';
    if (nav) nav.style.background = 'linear-gradient(to bottom, rgba(20,18,16,0.85) 0%, transparent 100%)';

    const planetEls = Array.from(document.querySelectorAll<HTMLElement>('.theme-planet'));

    // ── STATE RESET (ClientRouter Back-Navigation) ──
    controller?.destroy();
    caption?.destroy();
    controller = null;
    caption = null;
    gsap.killTweensOf(planetEls);
    planetEls.forEach(el => { el.style.cssText = ''; });

    // ── Größen ──
    planetEls.forEach((el, i) => {
      const size = responsivePlanetSize(BASE_SIZES[i % BASE_SIZES.length]);
      el.style.width  = `${size}px`;
      el.style.height = `${size}px`;
    });

    // ── Caption-Sync (Modell B+: Caption folgt Zentrierung, kein Zoom-Schritt) ──
    const captionRoot = document.getElementById('carousel-caption');
    if (captionRoot) {
      caption = createCaptionSync({
        root: captionRoot,
        eyebrow: document.getElementById('cc-eyebrow'),
        titel: document.getElementById('cc-titel'),
        beschr: document.getElementById('cc-beschr'),
        cta: document.getElementById('cc-cta') as HTMLAnchorElement | null,
        ctaText: document.getElementById('cc-cta-text'),
      }, (el) => ({
        eyebrow: el.dataset.gruppe ?? '',
        titel:   el.dataset.titel ?? '',
        beschr:  el.dataset.beschreibung ?? '',
        href:    (el as HTMLAnchorElement).href,
        ctaText: 'Kapitel starten',
      }));
    }

    // ── Karussell (vertikal) ──
    const counterEl = document.getElementById('theme-stage-counter-current');
    controller = initCarousel({
      container: track,
      items: planetEls,
      orientation: 'vertical',
      // Max. 3 Planeten im Sichtfeld: ausgewählter + je 1 Nachbar oben/unten.
      // Gibt mehr Luft und wirkt hochwertiger (siehe linearTransformFor).
      maxVisible: 1,
      showHint: true,
      persistKey: 'titan-carousel:' + window.location.pathname,
      onCenterChange: (i, el) => {
        caption?.sync(el);
        if (counterEl) counterEl.textContent = String(i + 1);
      },
    });

    document.getElementById('theme-stage-prev')?.addEventListener('click', () => controller?.prev());
    document.getElementById('theme-stage-next')?.addEventListener('click', () => controller?.next());

    // ── Zoom-Zwischenschritt (#4): CTA öffnet den Fokus statt direkt zu
    // navigieren. „Weiter" führt dann in die Lernseite des Kapitels. ──
    initFocusView();
    const cta = document.getElementById('cc-cta') as HTMLAnchorElement | null;
    cta?.addEventListener('click', (e) => {
      if (cta.classList.contains('is-disabled') || !cta.getAttribute('href')) return;
      e.preventDefault();
      const idx = controller?.getCenterIndex() ?? 0;
      const globe = planetEls[idx];
      if (!globe) { window.location.href = cta.href; return; }
      openFocus(globe, {
        eyebrow: globe.dataset.gruppe ?? '',
        titel:   globe.dataset.titel ?? '',
        beschr:  globe.dataset.beschreibung ?? '',
        meta:    '',
        href:    (globe as HTMLAnchorElement).href,
        weiterText: 'Kapitel starten',
      });
    });
  }

  // astro:page-load feuert bereits beim initialen Laden (Astro-Standard) —
  // ein zusätzlicher direkter Aufruf würde initPage() doppelt ausführen.
  document.addEventListener('astro:page-load', initPage);
</script>

<style>
  /* ── HEADER ─────────────────────────────── */
  .uih-back-link {
    font-family: var(--mono, monospace);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #5E5450;
    text-decoration: none;
    white-space: nowrap;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
    padding: 4px 0;
  }
  .uih-back-link:hover { color: #6E5035; }

  .ui-hdr {
    position: fixed;
    top: 56px; /* Unterhalb space-nav */
    left: 0; right: 0;
    z-index: 20;
    padding: 12px 24px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    background: linear-gradient(to bottom, rgba(20,18,16,0.9) 0%, transparent 100%);
  }

  .uih-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    justify-self: center;
  }

  .uih-nr {
    font-family: var(--mono, monospace);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(110, 80, 53, 0.45);
  }

  .uih-titel {
    font-family: var(--mono, monospace);
    font-size: clamp(10px, 1.2vw, 13px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6E5035;
    font-weight: 400;
    text-align: center;
  }

  .uih-count {
    font-family: var(--mono, monospace);
    font-size: 10px;
    color: rgba(110, 80, 53, 0.35);
    justify-self: end;
  }

  /* ── ZUGÄNGLICHE LISTE ──────────────────── */
  /* visibility:hidden statt der klassischen "clip"-Technik: auf dem Desktop
     ist das 3D-Karussell selbst die Navigation (eigene Fokus-Reihenfolge,
     eigenes aria-label) — die Liste soll dort NICHT zusätzlich per Tab
     erreichbar/für Screenreader sichtbar sein, sonst verdoppelt sich jeder
     Themen-Link (erst Karussell, dann unsichtbar diese Liste). Erst wenn
     sie tatsächlich die einzige Navigation ist (Mobile/reduced-motion),
     wird sie wieder normal sichtbar UND fokussierbar. */
  .theme-list-sr {
    visibility: hidden;
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
  }

  @media (max-width: 600px), (prefers-reduced-motion: reduce) {
    .theme-list-sr {
      visibility: visible;
      position: static;
      width: auto; height: auto;
      overflow: visible;
      padding: 130px 20px 48px;
    }
    .tls-gruppe { margin-bottom: 24px; }
    .tls-gruppe-titel {
      font-family: var(--mono, monospace);
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      color: #6E5035; margin-bottom: 8px; max-width: none;
    }
    .tls-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px 0; border-bottom: 1px solid rgba(110, 80, 53, 0.12);
      text-decoration: none; color: #1C1917;
      font-family: var(--serif, Georgia); font-size: 15px; font-weight: 300;
    }
    .tls-item::after { content: '→'; color: rgba(110, 80, 53, 0.4); }
    .tls-item:hover { color: #6E5035; }
  }

  /* ── RESPONSIVE HEADER ──────────────────── */
  @media (max-width: 640px) {
    .ui-hdr { grid-template-columns: auto 1fr auto; gap: 8px; }
    .uih-count { display: none; }
  }
  @media (max-width: 400px) {
    .uih-center { display: none; }
  }
</style>
