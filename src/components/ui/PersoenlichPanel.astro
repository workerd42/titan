---
import { BEREICHE } from '../../data/bereiche';

interface Props {
  alleThemenSlugs: Record<string, string[]>;
}
const { alleThemenSlugs } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!-- Modal (Trigger sitzt im Speed-Dial, siehe SpeedDial.astro) -->
<aside id="persoenlich-panel" class="persoenlich-modal" role="dialog" aria-modal="true" aria-label="Persönlicher Bereich" hidden>
  <div class="pm-box">
  <button class="pp-close" id="pp-close" aria-label="Schließen">×</button>

  <section class="pp-sektion" aria-labelledby="pp-a-h">
    <h3 id="pp-a-h" class="pp-sektion-titel">Konto</h3>
    <div id="pp-auth-out">
      <p class="pp-muted-text">Nicht angemeldet — Fortschritt nur auf diesem Gerät.</p>
      <a class="pp-link-btn" id="pp-login-link" href={`${base}konto/`}>Anmelden / Registrieren →</a>
    </div>
    <div id="pp-auth-in" hidden>
      <p class="pp-firma-meta" id="pp-auth-email">—</p>
      <p class="pp-muted-text pp-sync-note">Fortschritt wird synchronisiert.</p>
      <a class="pp-link-btn pp-link-btn--small" id="pp-admin-link" href={`${base}admin/`} hidden>Admin-Panel →</a>
      <button class="pp-link-btn pp-link-btn--small" id="pp-logout-btn" type="button">Abmelden</button>
    </div>
  </section>

  <div class="pp-divider"></div>

  <section class="pp-sektion" aria-labelledby="pp-k-h">
    <h3 id="pp-k-h" class="pp-sektion-titel">Kompass-Unternehmen</h3>
    <div id="pp-kompass-leer">
      <p class="pp-muted-text">Noch nicht eingerichtet.</p>
      <button class="pp-link-btn" id="pp-setup-btn" type="button">Jetzt einrichten →</button>
    </div>
    <div id="pp-kompass-data" hidden>
      <p class="pp-firma-name" id="pp-firma-name">—</p>
      <p class="pp-firma-meta" id="pp-firma-meta">—</p>
      <button class="pp-link-btn pp-link-btn--small" id="pp-edit-btn" type="button">Bearbeiten</button>
    </div>
  </section>

  <div class="pp-divider"></div>

  <section class="pp-sektion" aria-labelledby="pp-f-h">
    <h3 id="pp-f-h" class="pp-sektion-titel">Fortschritt</h3>
    {BEREICHE.map((b) => {
      const slugs = alleThemenSlugs[b.id] ?? [];
      return (
        <a href={`${base}${b.universumId}/${b.id}/`} class="pp-hb-zeile" data-progress-hb={b.id} data-hb-slugs={JSON.stringify(slugs)}>
          <span class="pp-hb-nr">HF {b.nummer}</span>
          <div class="pp-bar"><div class="pp-bar-fill" id={`pp-fill-${b.id}`}></div></div>
          <span class="pp-hb-pct" id={`pp-pct-${b.id}`}>0 %</span>
          <div class="pp-konst" id={`pp-konst-${b.id}`} aria-hidden="true"></div>
        </a>
      );
    })}
  </section>

  <div class="pp-divider"></div>

  <section class="pp-sektion">
    <div class="pp-streak">
      <p class="pp-streak-label">Lernstreak</p>
      <p class="pp-streak-val" id="pp-streak-val">—</p>
    </div>
  </section>

  <div class="pp-divider"></div>

  <section class="pp-sektion" aria-labelledby="pp-deck-h">
    <h3 id="pp-deck-h" class="pp-sektion-titel">Präsentations-Deck</h3>
    <p class="pp-muted-text">Deine gesammelten Artefakte für die IHK-Präsentation.</p>
    <a class="pp-link-btn" href={`${base}deck/`}>Deck ansehen →</a>
  </section>
  </div>
</aside>

<style>
  /* ── MODAL (Overlay + zentrierte Box) ── */
  .persoenlich-modal {
    position: fixed; inset: 0; z-index: 250;
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    background: rgba(8,6,4,0.62);
    backdrop-filter: blur(4px);
  }
  .persoenlich-modal[hidden] { display: none; }

  .pm-box {
    position: relative;
    width: min(600px,92vw); max-height: 88vh; overflow-y: auto;
    background: rgba(14,12,10,0.98);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 4px;
    padding: 48px 40px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.5);
    animation: pmIn 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  /* Breite nutzen: Inhalte zweispaltig fließen lassen (Konto/Kompass links,
     Fortschritt/Streak/Deck rechts). Der absolute Schließen-Button bleibt
     unberührt. */
  @media (min-width: 560px) {
    .pm-box { column-count: 2; column-gap: 36px; }
    .pm-box .pp-sektion { break-inside: avoid; margin-bottom: 24px; }
    .pm-box .pp-divider { display: none; }
  }
  @keyframes pmIn {
    from { opacity: 0; transform: translateY(12px) scale(0.985); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) { .pm-box { animation: none; } }

  .pp-close {
    position: absolute; top: 12px; right: 14px;
    font-size: 20px; color: rgba(255,255,255,.35); background: none;
    border: none; cursor: pointer; padding: 6px 8px; line-height: 1;
    transition: color .2s ease; min-height: 44px;
  }
  .pp-close:hover { color: rgba(255,255,255,.75); }

  .pp-sektion { margin-bottom: 20px; }
  .pp-sektion-titel {
    font-family: var(--mono,monospace); font-size: 10px; letter-spacing: .22em;
    text-transform: uppercase; color: rgba(196,168,130,.6); margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .pp-sektion-titel::before { content: ''; width: 18px; height: 1px; background: rgba(196,168,130,.4); flex-shrink: 0; }
  .pp-divider { height: 1px; background: rgba(255,255,255,.06); margin: 20px 0; }

  .pp-muted-text { font-family: var(--mono,monospace); font-size: 12px; color: rgba(255,255,255,.28); margin-bottom: 10px; max-width: none; }
  .pp-link-btn {
    font-family: var(--mono,monospace); font-size: 10px; letter-spacing: .14em;
    text-transform: uppercase; color: rgba(196,168,130,.7); background: none;
    border: none; cursor: pointer; padding: 0; min-height: 44px; transition: color .2s ease;
  }
  .pp-link-btn:hover { color: rgba(196,168,130,1); }
  .pp-link-btn--small { font-size: 9px; opacity: .6; display: block; }
  .pp-sync-note { color: rgba(122,200,152,.75); margin-bottom: 6px; }
  a.pp-link-btn { text-decoration: none; display: inline-block; line-height: 44px; }
  .pp-link-btn--small:hover { opacity: 1; }

  .pp-firma-name {
    font-family: var(--serif,Georgia,serif); font-size: 18px; font-weight: 300;
    color: #fff; margin-bottom: 4px; max-width: none;
  }
  .pp-firma-meta { font-family: var(--mono,monospace); font-size: 11px; color: rgba(255,255,255,.4); margin-bottom: 10px; max-width: none; line-height: 1.5; }

  .pp-hb-zeile {
    display: grid; grid-template-columns: 36px 1fr 38px;
    align-items: center; gap: 10px; margin-bottom: 10px;
    text-decoration: none; padding: 4px 0; transition: opacity .2s ease;
  }
  .pp-hb-zeile:hover { opacity: .8; }
  .pp-hb-nr { font-family: var(--mono,monospace); font-size: 10px; letter-spacing: .1em; color: rgba(196,168,130,.6); }
  .pp-bar { height: 2px; background: rgba(255,255,255,.08); overflow: hidden; }
  .pp-bar-fill { height: 100%; background: rgba(196,168,130,.7); width: 0%; transition: width .8s cubic-bezier(0.16,1,0.3,1); }
  .pp-hb-pct { font-family: var(--mono,monospace); font-size: 9px; color: rgba(255,255,255,.28); text-align: right; }
  .pp-konst { grid-column: 1 / -1; display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px; min-height: 5px; }

  .pp-streak { display: flex; align-items: baseline; justify-content: space-between; }
  .pp-streak-label { font-family: var(--mono,monospace); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.25); max-width: none; }
  .pp-streak-val { font-family: var(--serif,Georgia,serif); font-size: 24px; font-weight: 300; color: rgba(196,168,130,.8); max-width: none; }

  @media (max-width: 600px) {
    .persoenlich-modal { align-items: flex-end; padding: 0; }
    .pm-box {
      width: 100%; max-width: 100%; max-height: 86vh;
      border-radius: 8px 8px 0 0;
      padding: 40px 22px calc(24px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>

<!-- Sternbild-Sterne werden client-seitig per innerHTML injiziert → scoped CSS
     greift dort nicht, daher global. -->
<style is:global>
  #persoenlich-panel .pp-star { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.16); transition: background .5s ease, box-shadow .5s ease; }
  #persoenlich-panel .pp-star.lit { background: #C4A882; box-shadow: 0 0 6px rgba(196,168,130,.9); }
  #persoenlich-panel .pp-konst.complete .pp-star.lit { box-shadow: 0 0 8px rgba(196,168,130,1); animation: pp-twinkle 3.2s ease-in-out infinite; }
  @keyframes pp-twinkle { 0%, 100% { opacity: 1; } 50% { opacity: .55; } }
  @media (prefers-reduced-motion: reduce) { #persoenlich-panel .pp-konst.complete .pp-star.lit { animation: none; } }
</style>

<script>
  const KOMPASS_KEY  = 'norive-kompass-v1';
  const PROGRESS_KEY = 'norive-progress-v2';
  const FIRST_KEY    = 'titan-first-visit';

  // ── STABILE FUNKTIONEN: fragen DOM bei jedem Aufruf frisch ab ──
  function openPanel() {
    const panel  = document.getElementById('persoenlich-panel');
    const toggle = document.getElementById('persoenlich-toggle');
    if (!panel || !toggle) return;
    panel.removeAttribute('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    render();
    const kp = document.getElementById('konzept-panel');
    const kt = document.getElementById('konzept-toggle');
    if (kp && !kp.hidden) { kp.setAttribute('hidden', ''); kt?.setAttribute('aria-expanded', 'false'); }
    window.dispatchEvent(new CustomEvent('titan:meinbereich-opened'));
  }

  function closePanel() {
    const panel  = document.getElementById('persoenlich-panel');
    const toggle = document.getElementById('persoenlich-toggle');
    panel?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  function openOnboarding() {
    const ov = document.getElementById('kompass-onboarding');
    if (ov) { ov.removeAttribute('hidden'); ov.hidden = false; }
  }

  function renderKompass() {
    const data = (() => { try { return JSON.parse(localStorage.getItem(KOMPASS_KEY) || 'null'); } catch { return null; } })();
    const leer   = document.getElementById('pp-kompass-leer');
    const filled = document.getElementById('pp-kompass-data');
    if (data?.name) {
      if (leer)   leer.hidden = true;
      if (filled) filled.hidden = false;
      const n = document.getElementById('pp-firma-name');
      const m = document.getElementById('pp-firma-meta');
      if (n) n.textContent = data.name;
      const BL = { handel:'Handel', industrie:'Industrie', dienstleistung:'Dienstleistung', handwerk:'Handwerk', sonstiges:'Sonstiges' };
      const GL = { mikro:'< 10 MA', klein:'10–49 MA', mittel:'50–249 MA', gross:'250+ MA' };
      if (m) m.textContent = [data.rechtsform, BL[data.branche], GL[data.groesse]].filter(Boolean).join(' · ');
    } else {
      if (leer)   leer.hidden = false;
      if (filled) filled.hidden = true;
    }
  }

  function renderProgress() {
    const state  = (() => { try { return JSON.parse(localStorage.getItem(PROGRESS_KEY) || '{}'); } catch { return {}; } })();
    const themen = (state).themen ?? {};
    document.querySelectorAll('[data-progress-hb]').forEach((row) => {
      const hbId  = row.getAttribute('data-progress-hb') ?? '';
      let slugs = [];
      try { slugs = JSON.parse(row.getAttribute('data-hb-slugs') || '[]'); } catch { slugs = []; }
      if (!slugs.length) return;
      const total = slugs.length * 4;
      let done = 0;
      slugs.forEach((s) => { const t = themen[s] ?? {}; done += (t.verstehen?1:0)+(t.merken?1:0)+(t.anwenden?1:0)+(t.pruefen?1:0); });
      const pct = Math.round((done / total) * 100);
      const fill  = document.getElementById(`pp-fill-${hbId}`);
      const pctEl = document.getElementById(`pp-pct-${hbId}`);
      if (fill)  fill.style.width  = `${pct}%`;
      if (pctEl) pctEl.textContent = `${pct} %`;

      // Sternbild: ein Stern je Thema, leuchtet bei voller Meisterung (4/4 Phasen);
      // ist das ganze Handlungsfeld gemeistert, glüht die Konstellation.
      const konst = document.getElementById(`pp-konst-${hbId}`);
      if (konst) {
        const mastered = slugs.map((s) => { const t = themen[s] ?? {}; return !!(t.verstehen && t.merken && t.anwenden && t.pruefen); });
        konst.innerHTML = mastered.map((m) => `<span class="pp-star${m ? ' lit' : ''}"></span>`).join('');
        konst.classList.toggle('complete', mastered.length > 0 && mastered.every(Boolean));
      }
    });
    const sv = document.getElementById('pp-streak-val');
    if (sv) { const d = state.lernStreakTage ?? 0; sv.textContent = d > 0 ? `${d} Tag${d !== 1 ? 'e' : ''}` : '—'; }
  }

  /** Konto-Status: zeigt Anmelde-Link bzw. Email + Abmelden. */
  async function renderAuth() {
    const out = document.getElementById('pp-auth-out');
    const inn = document.getElementById('pp-auth-in');
    const mail = document.getElementById('pp-auth-email');
    if (!out || !inn) return;
    try {
      const res = await fetch('/api/auth/get-session', { headers: { Accept: 'application/json' } });
      const data = res.ok ? await res.json() : null;
      const user = data?.user ?? null;
      out.hidden = Boolean(user);
      inn.hidden = !user;
      if (user && mail) mail.textContent = user.email ?? '';
      const adminLink = document.getElementById('pp-admin-link');
      if (adminLink) adminLink.hidden = user?.role !== 'platform-admin';
    } catch {
      // Kein Backend erreichbar → anonymer Zustand anzeigen.
      out.hidden = false;
      inn.hidden = true;
    }
  }

  function render() { renderKompass(); renderProgress(); renderAuth(); }

  // ── PRO SEITE: Button-Listener neu anhängen + Anzeige aktualisieren
  // (Elemente werden bei jeder Astro-ClientRouter-Navigation ersetzt) ──
  function initPersoenlichPanel() {
    const toggle = document.getElementById('persoenlich-toggle');
    if (!toggle) return;

    toggle.addEventListener('click', () =>
      toggle.getAttribute('aria-expanded') === 'true' ? closePanel() : openPanel()
    );
    document.getElementById('pp-close')?.addEventListener('click', closePanel);
    document.getElementById('pp-setup-btn')?.addEventListener('click', openOnboarding);
    document.getElementById('pp-edit-btn')?.addEventListener('click', openOnboarding);

    document.getElementById('pp-logout-btn')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      btn.disabled = true;
      try {
        // Content-Type ist Pflicht — Better Auth lehnt Requests ohne ihn ab (415).
        await fetch('/api/auth/sign-out', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: '{}',
        });
        window.location.reload();
      } catch {
        btn.disabled = false;
      }
    });

    render();
  }

  document.addEventListener('astro:page-load', initPersoenlichPanel);

  // ── EINMALIG: document/window überleben Navigation, keine Dopplung ──
  document.addEventListener('keydown', (e) => {
    const toggle = document.getElementById('persoenlich-toggle');
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') closePanel();
  });

  document.addEventListener('click', (e) => {
    const toggle = document.getElementById('persoenlich-toggle');
    const panel  = document.getElementById('persoenlich-panel');
    if (!toggle || !panel || toggle.getAttribute('aria-expanded') !== 'true') return;
    const target = e.target as Node;
    // Klick auf den Backdrop (Overlay selbst, nicht die Box) schließt.
    if (target === panel) { closePanel(); return; }
    // Klick außerhalb von Modal UND Trigger schließt ebenfalls.
    if (!panel.contains(target) && !toggle.contains(target)) closePanel();
  });

  window.addEventListener('norive:kompass-updated', () => {
    render();
    const toggle = document.getElementById('persoenlich-toggle');
    if (toggle?.getAttribute('aria-expanded') !== 'true') openPanel();
  });
  window.addEventListener('norive:progress-updated', renderProgress);
  // Server-Sync: nur neu rendern, Panel NICHT aufklappen (im Gegensatz zu
  // 'norive:kompass-updated', das eine bewusste Nutzeraktion signalisiert).
  window.addEventListener('norive:synced', render);

  // Erster Besuch überhaupt: Panel einmalig nach Verzögerung öffnen
  // (nur beim allerersten Laden — FIRST_KEY verhindert Wiederholung)
  if (!localStorage.getItem(FIRST_KEY)) {
    localStorage.setItem(FIRST_KEY, '1');
    setTimeout(openPanel, 1800);
  }
</script>
