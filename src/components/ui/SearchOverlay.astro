---
/**
 * SearchOverlay.astro — Lupe oben rechts, öffnet eine zentrierte
 * Command-Palette (Spotlight/Cmd+K-Stil) über alle drei Hierarchieebenen
 * (Universum → Handlungsfeld → Thema).
 *
 * Der Suchindex (inkl. Volltext aller Themen) wird NICHT mehr pro Seite
 * inline eingebettet — das hätte den kompletten Markdown-Body aller 46
 * Themen auf jeder der 55 Seiten dupliziert (~150 KB extra, jedes Mal).
 * Stattdessen liegt er einmalig unter /search-index.json (siehe
 * src/pages/search-index.json.ts) und wird erst beim ersten Öffnen der
 * Suche nachgeladen und dann für die Session gecacht.
 */
const searchIndexUrl = `${import.meta.env.BASE_URL}search-index.json`;
---

<button
  class="search-toggle"
  id="search-toggle"
  aria-label="Suche öffnen"
  title="Suche (Universum, Handlungsfeld, Thema)"
  aria-expanded="false"
  aria-controls="search-overlay"
  data-index-url={searchIndexUrl}
>
  <svg viewBox="0 0 20 20" class="st-icon" aria-hidden="true">
    <circle cx="8.5" cy="8.5" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/>
    <line x1="13.2" y1="13.2" x2="18" y2="18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  </svg>
</button>

<div class="search-overlay" id="search-overlay" data-hidden role="dialog" aria-modal="true" aria-label="Suche">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <input
      type="text"
      id="search-input"
      class="search-input"
      placeholder="Suchen…"
      aria-label="Suche über Universum, Handlungsfeld und Thema"
      autocomplete="off"
      spellcheck="false"
    />
    <div class="search-results" id="search-results" role="listbox"></div>
    <p class="search-hint">↑↓ Navigieren · ↵ Öffnen · Esc Schließen</p>
  </div>
</div>

<style is:global>
  /* is:global: .sr-item & Co. werden client-seitig per innerHTML erzeugt und
     erhalten daher nie das Astro-Scoping-Attribut (data-astro-cid-*) — mit
     scoped CSS würden diese Regeln nie greifen. */
  .search-toggle {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 210;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(196, 168, 130, 0.5);
    background: rgba(20, 18, 16, 0.9);
    color: rgba(255, 255, 255, 0.85);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .search-toggle:hover { background: rgba(32, 28, 24, 0.95); border-color: rgba(196,168,130,0.4); color: rgba(255,255,255,0.9); }

  .st-icon { width: 19px; height: 19px; }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    justify-content: center;
    padding-top: min(14vh, 120px);
  }
  .search-overlay[data-hidden] { display: none; }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 9, 8, 0.6);
    backdrop-filter: blur(3px);
  }

  .search-panel {
    position: relative;
    z-index: 1;
    width: min(560px, 90vw);
    max-height: 68vh;
    background: rgba(20, 18, 16, 0.97);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .search-input {
    font-family: var(--serif, Georgia, serif);
    font-size: 20px;
    font-weight: 300;
    color: #fff;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 22px 24px;
    outline: none;
    /* Sicherheitsnetz falls der Placeholder auf sehr schmalen Displays
       dennoch nicht ganz passt — Ellipse statt hartem Abschneiden. */
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
  }
  .search-input::placeholder { color: rgba(255,255,255,0.3); }

  .search-results {
    overflow-y: auto;
    padding: 8px;
  }

  .sr-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    cursor: pointer;
    text-decoration: none;
    border-radius: 2px;
  }
  .sr-item[data-active="true"] { background: rgba(196,168,130,0.14); }

  .sr-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }

  .sr-titel {
    font-family: var(--serif, Georgia, serif);
    font-size: 15px;
    font-weight: 300;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sr-subtitel {
    font-family: var(--mono, monospace);
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sr-level {
    font-family: var(--mono, monospace);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(196,168,130,0.7);
    border: 1px solid rgba(196,168,130,0.3);
    padding: 3px 8px;
    flex-shrink: 0;
  }

  .search-empty {
    padding: 24px;
    font-family: var(--mono, monospace);
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    text-align: center;
  }

  .search-hint {
    font-family: var(--mono, monospace);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.25);
    padding: 10px 20px;
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: none;
  }

  @media (max-width: 600px) {
    .search-overlay { padding-top: 10vh; }
    .search-panel { width: 94vw; }
    .search-hint { display: none; }
  }
</style>

<script>
  interface SearchEntry { level: 'universum' | 'handlungsfeld' | 'thema'; title: string; subtitle: string; url: string; body?: string; }

  const LEVEL_LABELS: Record<SearchEntry['level'], string> = {
    thema: 'Thema',
    handlungsfeld: 'Handlungsfeld',
    universum: 'Universum',
  };
  const LEVEL_RANK: Record<SearchEntry['level'], number> = { thema: 0, handlungsfeld: 1, universum: 2 };

  function scoreEntry(entry: SearchEntry, q: string): number {
    const title = entry.title.toLowerCase();
    if (title === q) return 100;
    if (title.startsWith(q)) return 80;
    if (title.includes(q)) return 60;
    if (entry.subtitle.toLowerCase().includes(q)) return 40;
    // Volltext (Merksatz, Fallbeispiel, Prüfungsfrage, Definitionen, Werkzeug) —
    // niedrigste Priorität, aber findet z.B. "SWOT", was in Titel/Gruppe nie vorkommt.
    if (entry.body && entry.body.toLowerCase().includes(q)) return 20;
    return 0;
  }

  // Modul-Cache: einmal geladen, bleibt der Index für die gesamte Seiten-
  // Session im Speicher (kein erneuter Fetch bei jedem Öffnen der Suche).
  let indexCache: SearchEntry[] | null = null;
  let indexLoading: Promise<SearchEntry[]> | null = null;

  function loadIndex(url: string): Promise<SearchEntry[]> {
    if (indexCache) return Promise.resolve(indexCache);
    if (indexLoading) return indexLoading;
    indexLoading = fetch(url)
      .then((r) => r.json())
      .then((data: SearchEntry[]) => { indexCache = data; return data; })
      .catch(() => { indexCache = []; return []; });
    return indexLoading;
  }

  function initSearch(): void {
    const toggle  = document.getElementById('search-toggle');
    const overlay = document.getElementById('search-overlay');
    const input   = document.getElementById('search-input') as HTMLInputElement | null;
    const results = document.getElementById('search-results');
    if (!toggle || !overlay || !input || !results) return;

    const indexUrl = toggle.dataset.indexUrl ?? '';
    let activeIdx = 0;
    let currentResults: SearchEntry[] = [];

    function render(index: SearchEntry[]): void {
      const q = input!.value.trim().toLowerCase();
      if (!q) {
        results!.innerHTML = '';
        currentResults = [];
        return;
      }

      currentResults = index
        .map((entry) => ({ entry, score: scoreEntry(entry, q) }))
        .filter((r) => r.score > 0)
        .sort((a, b) => b.score - a.score || LEVEL_RANK[a.entry.level] - LEVEL_RANK[b.entry.level])
        .slice(0, 9)
        .map((r) => r.entry);

      activeIdx = 0;

      if (!currentResults.length) {
        results!.innerHTML = '<p class="search-empty">Keine Treffer.</p>';
        return;
      }

      results!.innerHTML = currentResults.map((entry, i) => `
        <a class="sr-item" href="${entry.url}" data-idx="${i}" data-active="${i === activeIdx}" role="option">
          <span class="sr-main">
            <span class="sr-titel">${entry.title}</span>
            <span class="sr-subtitel">${entry.subtitle}</span>
          </span>
          <span class="sr-level">${LEVEL_LABELS[entry.level]}</span>
        </a>
      `).join('');
    }

    function setActive(i: number): void {
      if (!currentResults.length) return;
      activeIdx = ((i % currentResults.length) + currentResults.length) % currentResults.length;
      results!.querySelectorAll<HTMLElement>('.sr-item').forEach((el) => {
        el.dataset.active = String(Number(el.dataset.idx) === activeIdx);
      });
      results!.querySelector<HTMLElement>('[data-active="true"]')?.scrollIntoView({ block: 'nearest' });
    }

    function open(): void {
      overlay!.removeAttribute('data-hidden');
      toggle!.setAttribute('aria-expanded', 'true');
      input!.value = '';
      results!.innerHTML = '';
      setTimeout(() => input!.focus(), 10);
      loadIndex(indexUrl); // beim Öffnen vorladen, damit Tippen sofort Ergebnisse zeigt
    }

    function close(): void {
      overlay!.setAttribute('data-hidden', '');
      toggle!.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', () => {
      overlay!.hasAttribute('data-hidden') ? open() : close();
    });

    document.getElementById('search-backdrop')?.addEventListener('click', close);

    input.addEventListener('input', () => {
      loadIndex(indexUrl).then(render);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIdx + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(activeIdx - 1); }
      else if (e.key === 'Enter') {
        e.preventDefault();
        const target = currentResults[activeIdx];
        if (target) window.location.href = target.url;
      } else if (e.key === 'Escape') {
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (overlay!.hasAttribute('data-hidden') && (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        open();
      } else if (!overlay!.hasAttribute('data-hidden') && e.key === 'Escape') {
        close();
      }
    });
  }

  document.addEventListener('astro:page-load', initSearch);
</script>
