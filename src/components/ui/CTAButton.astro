---
interface Props {
  href?: string;
  variant?: 'light' | 'dark' | 'back';
  label?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'light',
  label = 'Weiter',
  type = 'button',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['cta-arrow', `cta-arrow--${variant}`, className]}
  href={href}
  type={!href ? type : undefined}
  aria-label={label}
>
  <span class="cta-arrow-text"><slot>{label}</slot></span>
  <span class="cta-arrow-icon" aria-hidden="true">
    <span class="cta-arrow-line"></span>
  </span>
</Tag>

<style>
  .cta-arrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    min-height: 44px; /* WCAG touch target */
  }

  .cta-arrow-text {
    font-family: var(--mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .cta-arrow-icon {
    display: flex;
    align-items: center;
  }

  .cta-arrow-line {
    display: block;
    position: relative;
    width: 32px;
    height: 1px;
    transition: width var(--dur-fast) var(--ease);
  }

  .cta-arrow-line::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    width: 7px;
    height: 7px;
    border-right: 1px solid currentColor;
    border-top: 1px solid currentColor;
    transform: rotate(45deg);
  }

  /* Varianten */
  .cta-arrow--light .cta-arrow-text,
  .cta-arrow--light .cta-arrow-line {
    color: var(--accent);
  }

  .cta-arrow--light .cta-arrow-line,
  .cta-arrow--light .cta-arrow-line::after {
    background: var(--accent);
    border-color: var(--accent);
  }

  .cta-arrow--dark .cta-arrow-text {
    color: var(--accent);
  }

  .cta-arrow--dark .cta-arrow-line {
    background: var(--accent);
  }

  .cta-arrow--dark .cta-arrow-line::after {
    border-color: var(--accent);
  }

  /* Zurück: Pfeil links */
  .cta-arrow--back {
    flex-direction: row-reverse;
  }

  .cta-arrow--back .cta-arrow-line::after {
    right: unset;
    left: -1px;
    transform: rotate(-135deg);
  }

  .cta-arrow--back .cta-arrow-text,
  .cta-arrow--back .cta-arrow-line {
    color: var(--text-muted);
  }

  .cta-arrow--back .cta-arrow-line {
    background: var(--text-muted);
  }

  .cta-arrow--back .cta-arrow-line::after {
    border-color: var(--text-muted);
  }

  /* Hover */
  .cta-arrow:hover .cta-arrow-line {
    width: 52px;
  }

  .cta-arrow--back:hover .cta-arrow-line {
    width: 52px;
  }

  .cta-arrow--back:hover .cta-arrow-text,
  .cta-arrow--back:hover .cta-arrow-line {
    color: var(--text);
  }

  .cta-arrow--back:hover .cta-arrow-line {
    background: var(--text);
  }

  .cta-arrow--back:hover .cta-arrow-line::after {
    border-color: var(--text);
  }
</style>
