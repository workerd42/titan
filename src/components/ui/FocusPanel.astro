---
/**
 * FocusPanel — STATE 2 Detail-Overlay (linke Bildhälfte)
 * Typografisches Norive-Panel: Eyebrow, H1, Beschreibung, CTA, Back.
 * Wird vom gsap-focus.ts Controller gesteuert.
 * Initial versteckt via data-hidden + pointer-events:none.
 */
---

<aside id="focus-panel" class="focus-panel" data-hidden aria-label="Detail-Ansicht">
  <div class="fp-inner">
    <button id="fp-back" class="fp-back" type="button">← Zurück zum System</button>

    <p class="fp-eyebrow" id="fp-eyebrow"></p>
    <h1 class="fp-titel" id="fp-titel"></h1>
    <span class="fp-accent-line" aria-hidden="true"></span>
    <p class="fp-beschr" id="fp-beschr"></p>

    <a class="fp-cta" id="fp-cta" href="#">
      <span id="fp-cta-text"></span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<style>
  /* ── OVERLAY: linke Bildhälfte, reine Typografie auf Linen ── */
  .focus-panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(560px, 48vw);
    z-index: 90;
    display: flex;
    align-items: center;
    padding: 0 clamp(28px, 5vw, 72px);
    /* Kein eigener Hintergrund — Linen-Stage scheint durch */
    pointer-events: none;
  }

  .focus-panel[data-hidden] .fp-inner { opacity: 0; }

  .fp-inner {
    width: 100%;
    max-width: 460px;
  }

  /* Secondary Ghost Button */
  .fp-back {
    font-family: var(--mono, monospace);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(110, 80, 53, 0.65);
    background: transparent;
    border: 1px solid rgba(110, 80, 53, 0.28);
    cursor: pointer;
    padding: 10px 18px;
    min-height: 44px;
    margin-bottom: clamp(20px, 4vh, 44px);
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .fp-back:hover {
    color: #6E5035;
    border-color: rgba(110, 80, 53, 0.55);
    background: rgba(110, 80, 53, 0.05);
  }

  .fp-eyebrow {
    font-family: var(--mono, monospace);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(110, 80, 53, 0.6);
    margin-bottom: 14px;
    max-width: none;
  }

  .fp-titel {
    font-family: var(--serif, Georgia, serif);
    font-size: clamp(32px, 4.4vw, 56px);
    font-weight: 300;
    color: #1C1917;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin-bottom: 20px;
  }

  .fp-accent-line {
    display: block;
    width: 56px;
    height: 2px;
    background: #6E5035;
    margin-bottom: clamp(20px, 3.5vh, 32px);
  }

  .fp-beschr {
    font-family: var(--mono, monospace);
    font-size: 13px;
    font-weight: 300;
    color: #5E5450;
    line-height: 1.8;
    margin-bottom: clamp(28px, 5vh, 48px);
    max-width: 400px;
  }

  .fp-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--mono, monospace);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #141210;
    background: #C4A882;
    text-decoration: none;
    padding: 17px 30px;
    min-height: 52px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .fp-cta:hover {
    opacity: 0.88;
    transform: translateX(4px);
    text-decoration: none;
  }

  /* ── MOBILE: Panel unten, Hero oben ── */
  @media (max-width: 640px) {
    .focus-panel {
      top: auto;
      right: 0;
      width: 100%;
      height: 58vh;
      align-items: flex-start;
      padding: 28px 24px;
      background: linear-gradient(to top, rgba(237,232,223,0.99) 78%, transparent 100%);
    }
    .fp-titel { font-size: clamp(26px, 7vw, 34px); }
  }
</style>
