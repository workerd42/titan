---
// KonzeptPanel — rechte Seite, oberhalb von Mein Bereich
// Schließt automatisch wenn Mein Bereich geöffnet wird und umgekehrt
---

<!-- Toggle-Button (rechts, ÜBER Mein Bereich) -->
<button
  class="konzept-toggle"
  id="konzept-toggle"
  aria-label="Plattform-Konzept ansehen"
  aria-expanded="false"
  aria-controls="konzept-panel"
>
  <span class="kt-icon" aria-hidden="true">?</span>
  <span class="kt-label">Konzept</span>
</button>

<!-- Panel (öffnet von rechts) -->
<aside id="konzept-panel" class="konzept-panel" aria-label="Plattform-Konzept" hidden>
  <button class="kp-close" id="kp-close" aria-label="Konzept schließen">×</button>

  <header class="kp-header">
    <p class="kp-eyebrow">Was ist Titan?</p>
    <h2 class="kp-titel">Ein Kompetenzsystem, das dich entwickelt.</h2>
    <p class="kp-lead">
      Kein Kurs. Kein Skript. Titan begleitet dich durch die IHK-Prüfungsvorbereitung
      als durchgängige, praxisnahe Kompetenzreise.
    </p>
  </header>

  <div class="kp-inhalt">
    <section class="kp-section">
      <h3 class="kp-section-title">Die 4 Phasen</h3>
      {[
        { icon: '◉', phase: 'Verstehen',  farbe: '#6E7EA0', text: 'Wissensbibliothek mit Formeln, Definitionen, Rechenwegen.' },
        { icon: '◈', phase: 'Merken',     farbe: '#C4A882', text: 'Prägnanter Merksatz für die Prüfungssituation.' },
        { icon: '◆', phase: 'Anwenden',   farbe: '#5A8A6A', text: 'Fallbeispiel im Kontext deines Kompass-Unternehmens.' },
        { icon: '◎', phase: 'Prüfen',     farbe: '#8A7650', text: 'Echte IHK-Prüfungsfrage mit Lösungsweg.' },
      ].map(({ icon, phase, farbe, text }) => (
        <div class="kp-phase">
          <span class="kp-phase-icon" style={`color:${farbe}`} aria-hidden="true">{icon}</span>
          <div>
            <p class="kp-phase-name" style={`color:${farbe}`}>{phase}</p>
            <p class="kp-phase-text">{text}</p>
          </div>
        </div>
      ))}
    </section>

    <div class="kp-sep"></div>

    <section class="kp-section">
      <h3 class="kp-section-title">Kompass-Unternehmen</h3>
      <p class="kp-text">
        Beim ersten Besuch erstellst du einen digitalen Zwilling deines eigenen Unternehmens.
        Alle Fallbeispiele beziehen sich auf diesen Kontext.
        Nach Abschluss aller vier Handlungsfelder generiert Titan automatisch
        einen Präsentationsentwurf für die mündliche Prüfung.
      </p>
    </section>

    <div class="kp-sep"></div>

    <section class="kp-section">
      <h3 class="kp-section-title">Navigation</h3>
      <p class="kp-text">
        Klicke ein Handlungsfeld an — halte gedrückt und ziehe, um Planeten auf ihrer
        Bahn zu bewegen. Ein einfacher Klick öffnet die Details.
      </p>
    </section>

    <div class="kp-sep"></div>

    <section class="kp-section">
      <h3 class="kp-section-title">Prüfungsbezug</h3>
      <p class="kp-text">
        Titan bereitet auf die IHK-Fortbildungsprüfung
        <em>Geprüfte/r Fachwirt/in für Marketing</em> vor.
        Alle Inhalte orientieren sich am offiziellen Rahmenstoffplan.
      </p>
    </section>
  </div>
</aside>

<style>
  /* ── TOGGLE — rechte Seite, oberhalb Mein Bereich ── */
  .konzept-toggle {
    position: fixed;
    /* Fest über der Mitte, Mein Bereich ist UNTERHALB der Mitte */
    bottom: calc(50vh + 6px);
    right: 0;
    z-index: 50;
    background: rgba(20,18,16,0.92);
    border: 1px solid rgba(255,255,255,0.1);
    border-right: none;
    padding: 14px 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    backdrop-filter: blur(8px);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .konzept-toggle:hover,
  .konzept-toggle[aria-expanded="true"] {
    background: rgba(32,28,24,0.96);
    border-color: rgba(196,168,130,0.4);
  }

  .kt-icon {
    width: 18px;
    height: 18px;
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono, monospace);
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    line-height: 1;
    flex-shrink: 0;
  }

  .kt-label {
    font-family: var(--mono, monospace);
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    writing-mode: vertical-rl;
  }

  /* ── PANEL ──────────────────────────────── */
  .konzept-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(360px, 88vw);
    background: rgba(14,12,10,0.97);
    border-left: 1px solid rgba(255,255,255,0.08);
    z-index: 200;
    overflow-y: auto;
    padding: 48px 24px 48px;
    backdrop-filter: blur(12px);
    transform: translateX(100%);
    transition: transform 0.42s cubic-bezier(0.16,1,0.3,1);
  }

  .konzept-panel:not([hidden]) { transform: translateX(0); display: block; }
  .konzept-panel[hidden]       { display: block; transform: translateX(100%); pointer-events: none; }

  .kp-close {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 22px;
    color: rgba(255,255,255,0.35);
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 8px;
    min-height: 44px;
    line-height: 1;
    transition: color 0.2s ease;
  }
  .kp-close:hover { color: rgba(255,255,255,0.8); }

  /* ── INHALT ─────────────────────────────── */
  .kp-header {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .kp-eyebrow {
    font-family: var(--mono, monospace);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(196,168,130,0.55);
    margin-bottom: 8px;
    max-width: none;
  }

  .kp-titel {
    font-family: var(--serif, Georgia, serif);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 300;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .kp-lead {
    font-family: var(--mono, monospace);
    font-size: 12px;
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    line-height: 1.75;
    max-width: 320px;
  }

  .kp-section { margin-bottom: 20px; }

  .kp-section-title {
    font-family: var(--mono, monospace);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(196,168,130,0.6);
    margin-bottom: 12px;
  }

  .kp-sep {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 20px 0;
  }

  .kp-text {
    font-family: var(--mono, monospace);
    font-size: 12px;
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    line-height: 1.75;
    max-width: 320px;
  }

  .kp-text em { color: rgba(255,255,255,0.75); font-style: italic; }

  /* Phasen */
  .kp-phase {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .kp-phase-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }

  .kp-phase-name {
    font-family: var(--mono, monospace);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2px;
    max-width: none;
  }

  .kp-phase-text {
    font-family: var(--mono, monospace);
    font-size: 11px;
    font-weight: 300;
    color: rgba(255,255,255,0.42);
    line-height: 1.6;
    max-width: 280px;
  }

  /* ── RESPONSIVE ─────────────────────────── */
  @media (max-width: 600px) {
    .konzept-toggle {
      /* Mobile: neben Mein Bereich, beide unten rechts */
      top: auto;
      bottom: 80px;  /* Über dem Mein Bereich Toggle */
      right: 20px;
      transform: none;
      flex-direction: row;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 2px;
      padding: 8px 12px;
    }
    .kt-label { writing-mode: horizontal-tb; font-size: 9px; }

    .konzept-panel {
      top: auto;
      left: 0; right: 0; bottom: 0;
      width: 100%;
      height: 80vh;
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.08);
      transform: translateY(100%);
    }
    .konzept-panel:not([hidden]) { transform: translateY(0); }
    .konzept-panel[hidden]       { transform: translateY(100%); }
  }
</style>

<script>
  // ── STABILE FUNKTIONEN: fragen DOM bei jedem Aufruf frisch ab ──
  // Werden sowohl von den (bei jeder Navigation neu angehängten) Button-
  // Listenern als auch von den (nur einmal registrierten) document/window-
  // Listenern genutzt, damit nach ClientRouter-Navigation nie auf veraltete
  // Element-Referenzen zugegriffen wird.
  function openKonzept() {
    const panel  = document.getElementById('konzept-panel');
    const toggle = document.getElementById('konzept-toggle');
    if (!panel || !toggle) return;
    panel.removeAttribute('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    const mbPanel  = document.getElementById('persoenlich-panel');
    const mbToggle = document.getElementById('persoenlich-toggle');
    if (mbPanel && !mbPanel.hidden) {
      mbPanel.setAttribute('hidden', '');
      mbToggle?.setAttribute('aria-expanded', 'false');
    }
  }

  function closeKonzept() {
    const panel  = document.getElementById('konzept-panel');
    const toggle = document.getElementById('konzept-toggle');
    panel?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  // ── PRO SEITE: Button-Listener neu anhängen (Elemente werden bei jeder
  // Astro-ClientRouter-Navigation durch frische DOM-Knoten ersetzt) ──
  function initKonzeptPanel() {
    const toggle = document.getElementById('konzept-toggle');
    const close  = document.getElementById('kp-close');
    if (!toggle) return;

    toggle.addEventListener('click', () =>
      toggle.getAttribute('aria-expanded') === 'true' ? closeKonzept() : openKonzept()
    );
    close?.addEventListener('click', closeKonzept);
  }

  document.addEventListener('astro:page-load', initKonzeptPanel);

  // ── EINMALIG: document/window überleben Navigation, keine Dopplung ──
  document.addEventListener('keydown', (e) => {
    const toggle = document.getElementById('konzept-toggle');
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') closeKonzept();
  });

  document.addEventListener('click', (e) => {
    const toggle = document.getElementById('konzept-toggle');
    const panel  = document.getElementById('konzept-panel');
    if (!toggle || !panel || toggle.getAttribute('aria-expanded') !== 'true') return;
    const target = e.target as Node;
    if (!panel.contains(target) && !toggle.contains(target)) closeKonzept();
  });

  window.addEventListener('titan:meinbereich-opened', closeKonzept);
</script>
