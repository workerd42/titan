---
/**
 * CarouselStage.astro — horizontale Coverflow-Bühne (Seite 1 + 2)
 *
 * Ersetzt Universe.astro (Orbit-Ringe + Sonnenkörper entfallen — kein
 * Äquivalent im Karussell). Rendert eine Ziehfläche (.carousel-track) für
 * die Items, Pfeil-Buttons für Tastatur-lose Navigation, und einen
 * "caption"-Slot für die Seiten-spezifische CarouselCaption.
 *
 * Telemetrie: data-universum-id am Stage-Root (Dozenten-Dashboard, Phase 2).
 */
interface Props {
  stageId: string;
  universumId: string;
  itemCount: number;
}

const { stageId, universumId, itemCount } = Astro.props;
---

<div class="carousel-stage" id={stageId} data-universum-id={universumId}>
  <div class="carousel-track" id={`${stageId}-track`} tabindex="0" aria-label="Auswahl, mit Pfeiltasten navigierbar">
    <slot />
  </div>

  <button type="button" class="carousel-arrow carousel-arrow--prev" id={`${stageId}-prev`} aria-label="Vorheriges">
    <span aria-hidden="true">←</span>
  </button>
  <button type="button" class="carousel-arrow carousel-arrow--next" id={`${stageId}-next`} aria-label="Nächstes">
    <span aria-hidden="true">→</span>
  </button>

  {itemCount > 1 && (
    <div class="carousel-dots" id={`${stageId}-dots`} role="tablist" aria-label="Position">
      {Array.from({ length: itemCount }).map((_, i) => (
        <button
          type="button"
          class="carousel-dot"
          data-idx={i}
          data-active={i === 0 ? 'true' : 'false'}
          role="tab"
          aria-label={`Element ${i + 1} von ${itemCount}`}
        />
      ))}
    </div>
  )}

  <slot name="caption" />
</div>

<style>
  .carousel-stage {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    /* Dunkler Kosmos (Seite 1+2): erbt die Dark-Tokens von .space-shell —
       keine hellen Token-Overrides mehr (frühere „helle Insel"). */
    background: var(--bg);
  }

  .carousel-track {
    position: absolute;
    inset: 0;
    outline: none;
    /* Echte 3D-Tiefe statt manueller scale()-Annäherung: der Browser
       projiziert translateZ der Items selbst — Perspektive, Größe und
       Verdeckung ergeben sich aus echter Kameregeometrie. */
    perspective: 1300px;
    transform-style: preserve-3d;
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 80;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(196, 168, 130, 0.4);
    background: rgba(20, 18, 16, 0.55);
    color: var(--accent);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .carousel-arrow:hover { background: rgba(32, 28, 24, 0.85); border-color: rgba(196, 168, 130, 0.7); }
  .carousel-arrow--prev { left: clamp(12px, 3vw, 32px); }
  .carousel-arrow--next { right: clamp(12px, 3vw, 32px); }

  .carousel-dots {
    position: absolute;
    bottom: clamp(16px, 3vh, 28px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 80;
    display: flex;
    gap: 10px;
  }

  .carousel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(196, 168, 130, 0.3);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .carousel-dot:hover { background: rgba(196, 168, 130, 0.6); }
  .carousel-dot[data-active="true"] {
    background: var(--accent);
    transform: scale(1.3);
  }

  @media (max-width: 600px) {
    .carousel-arrow { width: 38px; height: 38px; }
  }
</style>
