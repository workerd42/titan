---
/**
 * Universe.astro — Kanonischer Stage-Wrapper (STATE 1–3 Bühne)
 *
 * Rendert: Orbitalringe (SVG), Zentralkörper, FocusPanel-Overlay (STATE 2),
 * und einen Slot für die Objekte (UniversumGlobe / Planet).
 *
 * Telemetrie: data-universum-id am Stage-Root für Dozenten-Dashboard (Phase 2).
 * Die GSAP-Steuerung (gsap-focus.ts / gsap-orbits.ts) wird von der Seite geladen.
 */
import FocusPanel from '../ui/FocusPanel.astro';

interface OrbitRing { rx: number; ry: number; }

interface Props {
  stageId: string;          // z.B. "solar-stage" | "theme-stage"
  centralId: string;        // z.B. "solar-center" | "theme-center"
  universumId: string;      // Telemetrie-ID, z.B. "titan-system" | "hb1"
  orbits: OrbitRing[];      // Ringe in % (viewBox 0 0 100 100)
  central: { h: string; b: string };  // Zentralkörper-Farben (highlight/base)
  centralLabel?: string;    // Optionales Label unter dem Zentralkörper
  centralSize?: 'lg' | 'sm';
  hideOnMobile?: boolean;   // Stage auf <600px ausblenden (SR-Liste übernimmt)
}

const {
  stageId, centralId, universumId, orbits, central,
  centralLabel, centralSize = 'sm', hideOnMobile = false,
} = Astro.props;

const uid = (s: string) => `${stageId}-${s}`;
const n = orbits.length;
---

<div
  class="orbit-stage"
  id={stageId}
  data-universum-id={universumId}
  data-hide-mobile={hideOnMobile ? 'true' : undefined}
>
  <!-- Orbitalringe -->
  <svg class="orbit-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <radialGradient id={uid('glow')} cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color={central.h} stop-opacity="0.30"/>
        <stop offset="55%" stop-color={central.b} stop-opacity="0.06"/>
        <stop offset="100%" stop-color="transparent"/>
      </radialGradient>
    </defs>

    <ellipse cx="50" cy="50" rx="13" ry="13" fill={`url(#${uid('glow')})`}/>

    {orbits.map((o, i) => (
      <ellipse
        cx="50" cy="50" rx={o.rx} ry={o.ry}
        fill="none"
        stroke={`rgba(110,80,53,${(0.14 + (n - i) * 0.028).toFixed(3)})`}
        stroke-width={(0.45 - i * 0.028).toFixed(3)}
        stroke-dasharray="1.0 2.1"
      />
    ))}
  </svg>

  <!-- Zentralkörper -->
  <div class={`orbit-central orbit-central--${centralSize}`} id={centralId} aria-hidden="true">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="oc-svg">
      <defs>
        <radialGradient id={uid('cg')} cx="36%" cy="30%" r="70%">
          <stop offset="0%"   stop-color="#FFFBF0"  stop-opacity="0.98"/>
          <stop offset="22%"  stop-color={central.h} stop-opacity="0.92"/>
          <stop offset="58%"  stop-color={central.b} stop-opacity="0.84"/>
          <stop offset="100%" stop-color="#100A04"   stop-opacity="0.95"/>
        </radialGradient>
        <radialGradient id={uid('ca')} cx="50%" cy="50%" r="50%">
          <stop offset="56%"  stop-color="transparent"/>
          <stop offset="100%" stop-color={`${central.h}55`}/>
        </radialGradient>
        <filter id={uid('cf')}>
          <feGaussianBlur stdDeviation="2.5" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      <circle cx="50" cy="50" r="50" fill={`url(#${uid('ca')})`}/>
      <circle cx="50" cy="50" r="43" fill={`url(#${uid('cg')})`}/>
      <ellipse cx="34" cy="30" rx="10" ry="7" fill="rgba(255,252,235,0.22)" filter={`url(#${uid('cf')})`}/>
      <circle cx="50" cy="50" r="5" fill="rgba(255,252,240,0.94)" filter={`url(#${uid('cf')})`}/>
    </svg>
    {centralLabel && <p class="oc-label">{centralLabel}</p>}
  </div>

  <!-- Objekte (UniversumGlobe / Planet) + seiten-spezifische Extras -->
  <slot />

  <!-- STATE 2: Detail-Panel Overlay -->
  <FocusPanel />
</div>

<style>
  .orbit-stage {
    position: relative;
    width: 100%;
    height: 100dvh;
    /* overflow:hidden entfernt — klippt sonst position:fixed Kinder (#focus-panel),
       exakt derselbe Bug wie M2.3 (space.css .space-shell). overflow-x:clip hält
       gedragte Planeten horizontal im Rahmen, ohne Fixed-Elemente aus der
       Darstellung zu schneiden. */
    overflow-x: clip;
    overflow-y: hidden;
    /* Norive Warm Linen — Illustrationsstil */
    background: #EDE8DF;
    --text: #1C1917;
    --text-muted: #5E5450;
    --accent: #6E5035;
  }

  .orbit-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .orbit-central {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    z-index: 5;
    pointer-events: none;
  }

  .orbit-central--lg { width: clamp(70px, 8vw, 100px); }
  .orbit-central--sm { width: clamp(56px, 6vw, 78px); }

  .oc-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .oc-label {
    font-family: var(--mono, monospace);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(110, 80, 30, 0.65);
    max-width: none;
    margin-top: -2px;
  }

  /* Mobile / reduced motion: Stage ausblenden, SR-Liste übernimmt */
  @media (max-width: 600px) {
    .orbit-stage[data-hide-mobile="true"] { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .orbit-stage[data-hide-mobile="true"] { display: none; }
  }
</style>
