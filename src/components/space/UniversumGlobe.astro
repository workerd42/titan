---
/**
 * UniversumGlobe.astro — Universum-Sphäre für die Universum-Auswahl (STATE 1 Objekt)
 *
 * Ebene 1 der Hierarchie: UNIVERSUM → Galaxie (HF) → Planet.
 * Strukturell identisch zu GalaxieGlobe.astro — gleiches Orbit-Drag- und
 * 3-State-Fokus-Verhalten, damit das System nahtlos skaliert sobald
 * weitere Universen (z. B. andere IHK-Zertifizierungen) hinzukommen.
 *
 * Klick wird von gsap-orbits.ts abgefangen (kein direktes href-Follow) und
 * löst über gsap-focus.ts die STATE-2-Transition aus. Navigation nur per CTA.
 *
 * Telemetrie-Kontrakt (Dozenten-/Admin-Dashboard, Phase 2):
 *   data-universum-id — Universum-Kennung (URL-Segment)
 */
interface Props {
  universumId: string;
  nummer: number;
  titel: string;
  eyebrow: string;
  beschreibung: string;
  href: string;
  galaxienCount: number;
  orbitIdx: number;
  startAngle: number;
  color: { highlight: string; base: string; rim: string; atmo: string };
}

const {
  universumId, nummer, titel, eyebrow, beschreibung, href,
  galaxienCount, orbitIdx, startAngle, color,
} = Astro.props;

const gId = (s: string) => `up-${universumId}-${s}`;
---

<a
  class="universum-planet"
  href={href}
  id={`universum-${universumId}`}
  data-universum-id={universumId}
  data-orbit={orbitIdx}
  data-start={startAngle}
  data-nummer={nummer}
  data-titel={titel}
  data-eyebrow={eyebrow}
  data-beschreibung={beschreibung}
  data-galaxien={galaxienCount}
  aria-label={`${eyebrow}: ${titel}`}
>
  <svg class="ps-sphere" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" overflow="visible">
    <defs>
      <radialGradient id={gId('g')} cx="35%" cy="30%" r="70%">
        <stop offset="0%"   stop-color={color.highlight} stop-opacity="0.96"/>
        <stop offset="40%"  stop-color={color.base}      stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#06040A"          stop-opacity="0.97"/>
      </radialGradient>
      <radialGradient id={gId('a')} cx="50%" cy="50%" r="50%">
        <stop offset="62%"  stop-color="transparent"/>
        <stop offset="100%" stop-color={color.atmo}/>
      </radialGradient>
      <radialGradient id={gId('r')} cx="68%" cy="65%" r="55%">
        <stop offset="0%"   stop-color="transparent"/>
        <stop offset="70%"  stop-color="transparent"/>
        <stop offset="100%" stop-color={color.rim}/>
      </radialGradient>
    </defs>
    <circle cx="50" cy="50" r="52" fill={`url(#${gId('a')})`}/>
    <circle cx="50" cy="50" r="44" fill={`url(#${gId('g')})`}/>
    <circle cx="50" cy="50" r="44" fill={`url(#${gId('r')})`}/>
    <ellipse cx="36" cy="33" rx="9" ry="6" fill="rgba(255,250,240,0.22)"/>
  </svg>

  <div class="universum-planet-label" aria-hidden="true">
    <span class="upl-eyebrow">{eyebrow}</span>
    <span class="upl-name">{titel}</span>
    <span class="upl-count">{galaxienCount} Handlungsfelder</span>
  </div>
</a>

<style>
  .universum-planet {
    position: absolute;
    display: block;
    text-decoration: none;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
    opacity: 0; /* Kein Flash bei 0,0 — JS positioniert und blendet ein */
  }
  .universum-planet:active { cursor: grabbing; }

  .ps-sphere {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
    transition: filter 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .universum-planet:hover .ps-sphere,
  .universum-planet:focus-visible .ps-sphere {
    filter:
      drop-shadow(0 0 16px rgba(196, 168, 130, 0.65))
      drop-shadow(0 0 40px rgba(196, 168, 130, 0.28));
  }

  .universum-planet:focus-visible {
    outline: 2px solid rgba(110, 80, 53, 0.6);
    outline-offset: 8px;
    border-radius: 50%;
  }

  .universum-planet-label {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
    white-space: nowrap;
    z-index: 50;
  }

  .universum-planet:hover .universum-planet-label,
  .universum-planet:focus-visible .universum-planet-label { opacity: 1; }

  .upl-eyebrow {
    font-family: var(--mono, monospace);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(110, 80, 53, 0.45);
  }

  .upl-name {
    font-family: var(--mono, monospace);
    font-size: 12px;
    font-weight: 400;
    color: #1C1917;
    background: rgba(237, 232, 223, 0.95);
    border: 1px solid rgba(110, 80, 53, 0.15);
    padding: 5px 12px;
    letter-spacing: 0.04em;
    max-width: 280px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .upl-count {
    font-family: var(--mono, monospace);
    font-size: 9px;
    color: rgba(110, 80, 53, 0.5);
    letter-spacing: 0.1em;
  }
</style>
