# Titan — Umgebungsvariablen (Vorlage).
# Echte Werte in eine gitignored .env kopieren. NIEMALS Secrets committen.

# ─────────────────────────────────────────────────────────────
# LOKALE ENTWICKLUNG (npm run dev / npm run db:migrate)
# Setzt ein lokales Postgres voraus, z.B.:
#   docker run -d --name titan-pg-dev \
#     -e POSTGRES_USER=titan -e POSTGRES_PASSWORD=titan -e POSTGRES_DB=titan \
#     -p 5432:5432 postgres:16-alpine
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://titan:titan@localhost:5432/titan
BETTER_AUTH_SECRET=change-me-generate-a-strong-random-secret
BETTER_AUTH_URL=http://localhost:4321

# ─────────────────────────────────────────────────────────────
# PRODUKTION (docker compose auf dem VPS)
# docker-compose.yml baut DATABASE_URL selbst aus diesen Werten zusammen —
# dort NICHT DATABASE_URL setzen, sondern:
# ─────────────────────────────────────────────────────────────
# POSTGRES_USER=titan
# POSTGRES_PASSWORD=<starkes-passwort>
# POSTGRES_DB=titan
# BETTER_AUTH_SECRET=<openssl rand -base64 32>
# BETTER_AUTH_URL=https://prototyp-staging.norive.de
