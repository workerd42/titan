# Titan — Umgebungsvariablen (Vorlage).
# Echte Werte in eine gitignored .env kopieren. NIEMALS Secrets committen.
#
# Zugangsdaten werden bewusst als EINZELFELDER übergeben, nicht als
# DATABASE_URL. Grund: In einer Verbindungs-URL (postgres://user:pass@host/db)
# zerreissen Sonderzeichen im Passwort — @ / : ? # % — die Syntax. Das ist beim
# ersten Deploy real passiert. Als Felder ist JEDES Passwort erlaubt.

# ─────────────────────────────────────────────────────────────
# LOKALE ENTWICKLUNG (npm run dev / npm run db:migrate)
# Setzt ein lokales Postgres voraus, z.B.:
#   docker run -d --name titan-pg-dev \
#     -e POSTGRES_USER=titan -e POSTGRES_PASSWORD=titan -e POSTGRES_DB=titan \
#     -p 5432:5432 postgres:16-alpine
# Lokal darf bewusst von Produktion abweichen.
# ─────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=titan
PGPASSWORD=titan
PGDATABASE=titan
BETTER_AUTH_SECRET=change-me-generate-a-strong-random-secret
BETTER_AUTH_URL=http://localhost:4321

# ─────────────────────────────────────────────────────────────
# PRODUKTION (docker compose auf dem VPS)
# Hier NICHT die PG*-Variablen setzen! docker-compose.yml übersetzt die
# folgenden POSTGRES_*-Werte intern nach PGHOST/PGUSER/... für den
# App-Container. Die .env-Schnittstelle bleibt also POSTGRES_*.
#
# ⚠️ Benutzer/Passwort/DB-Name werden von Postgres NUR beim allerersten Start
#    mit leerem Datenverzeichnis übernommen. Danach stecken sie im Volume fest;
#    eine spätere Änderung greift nicht mehr (dann: Volume löschen = Datenverlust,
#    oder manuell per SQL ändern). Also vor dem ersten `docker compose up`
#    festlegen.
#
# Bewusst NICHT der Projektname: 'titan' benennt das Projekt, nicht die
# Datenbank-Identität.
# ─────────────────────────────────────────────────────────────
# POSTGRES_USER=monarch
# POSTGRES_PASSWORD=<starkes-passwort — beliebige Zeichen erlaubt>
# POSTGRES_DB=hermes
# BETTER_AUTH_SECRET=<openssl rand -base64 32>
# BETTER_AUTH_URL=https://prototyp-staging.norive.de
